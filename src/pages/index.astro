---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/home/Hero.astro';
import About from '@/components/home/About.astro';
import Highlights from '@/components/home/Highlights.astro';
import Verticals from '@/components/home/Verticals.astro';
import Governance from '@/components/home/Governance.astro';
import Strategic from '@/components/home/Strategic.astro';
import Contact from '@/components/home/Contact.astro';
import { SITE } from '@/config/site';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": SITE.name,
  "description": SITE.description,
  "url": SITE.url,
  "logo": "https://pagesmith-cdn.com/347b1a00/images/SPVH-logo-01-Copy2-1536-1536-1536-1536.webp"
};
---

<BaseLayout 
  title={SITE.title} 
  description={SITE.description}
  jsonLd={jsonLd}
>
  <Hero />
  <About />
  <Highlights />
  <Verticals />
  <Governance />
  <Strategic />
  <Contact />
</BaseLayout>
