---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { SITE } from '@/config/site';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Our Programs | SPVH Group",
  "description": "Nurturing Startups, Fueling Success. Explore SPVH Group's investment programs, mentorship, and CSR initiatives.",
  "url": `${SITE.url}our-programs`
};
---

<BaseLayout title="Our Programs | SPVH Group" description="Nurturing Startups, Fueling Success. Explore SPVH Group's investment programs, mentorship, and CSR initiatives." jsonLd={jsonLd}>
  <!-- Program Deck Modal -->
  <div id="deck-modal" class="fixed inset-0 z-[100] hidden items-center justify-center p-4" data-ps="src/pages/our-programs.astro:x1jwqa">
    <div class="absolute inset-0 bg-black/80 backdrop-blur-sm" id="modal-backdrop" data-ps="src/pages/our-programs.astro:x1jwqb"></div>
    <div class="relative w-full max-w-[600px] bg-[#0A1931] border border-white/10 rounded-xl p-10 shadow-2xl z-10" data-ps="src/pages/our-programs.astro:lui32j">
      <button id="close-modal" class="absolute top-6 right-6 text-white/50 hover:text-white transition-colors" aria-label="Close modal" data-ps="src/pages/our-programs.astro:ig6myt">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
      </button>

      <div id="form-container" data-ps="src/pages/our-programs.astro:lui32i">
        <h2 class="text-2xl font-bold text-white mb-8" data-ps="src/pages/our-programs.astro:cd40uh">Access Program Deck</h2>
        <form id="deck-form" class="space-y-6">
          <div class="space-y-1" data-ps="src/pages/our-programs.astro:lui32h">
            <label for="name" class="block text-sm text-[#94A3B8]" data-ps="src/pages/our-programs.astro:etcm7b">Full Name</label>
            <input type="text" id="name" name="name" required class="w-full bg-transparent border-b border-white/20 py-2 text-white focus:outline-none focus:border-[#00A896] transition-colors" />
          </div>
          <div class="space-y-1" data-ps="src/pages/our-programs.astro:lui32g">
            <label for="email" class="block text-sm text-[#94A3B8]" data-ps="src/pages/our-programs.astro:etcm7a">Email</label>
            <input type="email" id="email" name="email" required class="w-full bg-transparent border-b border-white/20 py-2 text-white focus:outline-none focus:border-[#00A896] transition-colors" />
          </div>
          <div class="space-y-1" data-ps="src/pages/our-programs.astro:lui32f">
            <label for="linkedin" class="block text-sm text-[#94A3B8]" data-ps="src/pages/our-programs.astro:etcm6o">LinkedIn Profile</label>
            <input type="url" id="linkedin" name="linkedin" required class="w-full bg-transparent border-b border-white/20 py-2 text-white focus:outline-none focus:border-[#00A896] transition-colors" />
          </div>
          <div class="space-y-1" data-ps="src/pages/our-programs.astro:lui32e">
            <label for="about" class="block text-sm text-[#94A3B8]" data-ps="src/pages/our-programs.astro:etcm6n">Brief about yourself</label>
            <textarea id="about" name="about" required rows="3" class="w-full bg-transparent border-b border-white/20 py-2 text-white focus:outline-none focus:border-[#00A896] transition-colors resize-none"></textarea>
          </div>
          <div class="space-y-1" data-ps="src/pages/our-programs.astro:lui32d">
            <label for="program" class="block text-sm text-[#94A3B8]" data-ps="src/pages/our-programs.astro:etcm6m">Which program are you interested to explore?</label>
            <select id="program" name="program" required class="w-full bg-[#0A1931] border-b border-white/20 py-2 text-white focus:outline-none focus:border-[#00A896] transition-colors">
              <option value="" disabled selected>Select a program</option>
              <option value="Ideapreneur">Ideapreneur</option>
              <option value="Solopreneur">Solopreneur</option>
              <option value="Entrepreneur">Entrepreneur</option>
              <option value="Familypreneur">Familypreneur</option>
            </select>
          </div>
          
          <div class="pt-4" data-ps="src/pages/our-programs.astro:lui32c">
            <altcha-widget challenge="/psapi-internal-v1/altcha/challenge" display="invisible" auto="onfocus"></altcha-widget>
            <button type="submit" class="w-full bg-[#00A896] hover:bg-[#00A896]/90 text-white font-bold py-4 px-8 rounded-lg uppercase tracking-wide transition-all" data-ps="src/pages/our-programs.astro:ig6myu">
              Submit
            </button>
          </div>
        </form>
      </div>

      <div id="success-container" class="hidden flex-col items-center justify-center py-12 text-center" data-ps="src/pages/our-programs.astro:lui32b">
        <div class="w-16 h-16 bg-[#00A896] rounded-full flex items-center justify-center mb-6" data-ps="src/pages/our-programs.astro:lui32a">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
        </div>
        <h3 class="text-2xl font-bold text-white" data-ps="src/pages/our-programs.astro:2bawd4">Submitted</h3>
        <p class="text-[#94A3B8] mt-2" data-ps="src/pages/our-programs.astro:77ib71">Your download will start automatically.</p>
      </div>
    </div>
  </div>

  <!-- Section 1: Page Hero -->
  <section class="relative min-h-[70vh] flex items-center pt-20 overflow-hidden" data-ps="src/pages/our-programs.astro:koto0m">
    <div class="absolute inset-0 z-0" data-ps="src/pages/our-programs.astro:x1jwoj">
      <img 
        src="/images/pexels-rdne-7414219-1536.webp"
        sizes="100vw"
        alt="Corporate Collaboration" 
        class="w-full h-full object-cover"
        fetchpriority="high"
        loading="eager" data-ps="src/pages/our-programs.astro:ujasca" />
      <div class="absolute inset-0 bg-dark/70" data-ps="src/pages/our-programs.astro:x1jwok"></div>
    </div>
    
    <div class="container mx-auto px-4 relative z-10" data-ps="src/pages/our-programs.astro:x1jwol">
      <div class="max-w-4xl hero-animate" data-ps="src/pages/our-programs.astro:x1jwp7">
        <h1 class="text-4xl md:text-7xl font-bold text-white mb-4 tracking-tight" data-ps="src/pages/our-programs.astro:r1ixzh">
          We Want To <span class="text-secondary" data-ps="src/pages/our-programs.astro:ed2cbs">Invest</span> In You.
        </h1>
        <p class="text-xl md:text-2xl text-white/90 font-medium mb-6" data-ps="src/pages/our-programs.astro:77ib2r">
          Nurturing Startups, Fueling Success.
        </p>
        <div class="w-full max-w-2xl bg-white/10 backdrop-blur-md border border-white/20 p-8 rounded-2xl shadow-2xl" data-ps="src/pages/our-programs.astro:x1jwp8">
          <p class="text-lg text-white/80 leading-relaxed" data-ps="src/pages/our-programs.astro:77ib2s">SPVH Group extends its purpose of investing through fostering fresh enterprise at different intersection points. Whether you are at an idea stage or has reached a proof of concept or have found your market fit. We invest to become the first institutional cheque which goes beyond capital to discover your true enterprise potential.</p>
        </div>
        </div>


        </div>
        </section>

  <!-- Section 2: The Vision & Why Choose Us -->
  <section class="py-24 bg-white overflow-hidden" data-ps="src/pages/our-programs.astro:koto0n">
    <div class="container mx-auto px-4" data-ps="src/pages/our-programs.astro:x1jwp9">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center" data-ps="src/pages/our-programs.astro:x1jwpa">
        <div class="space-y-8" data-ps="src/pages/our-programs.astro:x1jwpb">
          <h2 class="text-3xl md:text-5xl font-bold text-dark tracking-tight" data-ps="src/pages/our-programs.astro:cd40ru">
            Why Our Programs?
          </h2>
          <div class="prose prose-lg text-muted-foreground" data-ps="src/pages/our-programs.astro:x1jwpc">
            <p data-ps="src/pages/our-programs.astro:77ib2t">Great ventures frequently begin in environments that fail to understand them. We back unconventional, overlooked individuals at the pure idea stage provided they bring absolute clarity to the problem they are solving and the solution they are building.</p>
            <p data-ps="src/pages/our-programs.astro:77ib2u">We eliminate the exhaustive search for external validation. Instead, our team of operators and investors works directly with you to refine your business model, offering the clarity and mentorship needed to run a successful company. Whether we are deploying your vital first round of capital or structuring your idea to be bulletproof for future funding, our mandate is simple: to actively nurture your startup from an invalidated concept into a market-ready reality, accelerating both your personal growth as a founder and the commercial success of your business. We are your partner in the Zero to One journey of you.</p>
          </div>
        </div>
        <div class="relative" data-ps="src/pages/our-programs.astro:x1jwpd">
          <div class="absolute -inset-4 bg-secondary/10 rounded-3xl -rotate-2" data-ps="src/pages/our-programs.astro:x1jwpe"></div>
          <img 
            src="https://images.pexels.com/photos/6170758/pexels-photo-6170758.jpeg?auto=compress&cs=tinysrgb&w=1200" 
            srcset="https://images.pexels.com/photos/6170758/pexels-photo-6170758.jpeg?auto=compress&cs=tinysrgb&w=320 320w, https://images.pexels.com/photos/6170758/pexels-photo-6170758.jpeg?auto=compress&cs=tinysrgb&w=480 480w, https://images.pexels.com/photos/6170758/pexels-photo-6170758.jpeg?auto=compress&cs=tinysrgb&w=640 640w, https://images.pexels.com/photos/6170758/pexels-photo-6170758.jpeg?auto=compress&cs=tinysrgb&w=768 768w, https://images.pexels.com/photos/6170758/pexels-photo-6170758.jpeg?auto=compress&cs=tinysrgb&w=1024 1024w, https://images.pexels.com/photos/6170758/pexels-photo-6170758.jpeg?auto=compress&cs=tinysrgb&w=1280 1280w, https://images.pexels.com/photos/6170758/pexels-photo-6170758.jpeg?auto=compress&cs=tinysrgb&w=1920 1920w"
            sizes="(max-width: 1024px) 100vw, 50vw"
            alt="Handshake Agreement" 
            class="relative z-10 w-full h-[500px] object-cover rounded-2xl shadow-2xl"
            loading="lazy" data-ps="src/pages/our-programs.astro:ujascw" />
        </div>
      </div>
    </div>
  </section>

  <!-- Section 3: Program Segments (4 Column Grid) -->
  <section class="py-24 bg-dark relative overflow-hidden" data-ps="src/pages/our-programs.astro:koto0p">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(72,106,173,0.1),transparent)]" data-ps="src/pages/our-programs.astro:x1jwq5"></div>
    <div class="w-full max-w-[1440px] mx-auto px-4 lg:px-8 relative z-10" data-ps="src/pages/our-programs.astro:x1jwq6">
      <!-- Header -->
      <div class="text-center mb-12" data-ps="src/pages/our-programs.astro:program-header">
        <h2 class="text-3xl md:text-5xl font-bold text-[#FFFFFF] mb-4 tracking-tight" data-ps="src/pages/our-programs.astro:program-title">Program Highlights</h2>
        <p class="text-lg text-[#94A3B8] max-w-3xl mx-auto leading-relaxed" data-ps="src/pages/our-programs.astro:program-brief">
          Explore our structured investment pathways tailored for every stage of your journey. From genesis-stage validation to multi-generational scaling, we provide the exact capital and operational guidance you need.
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-4 gap-6 lg:gap-8" data-ps="src/pages/our-programs.astro:x1jwq7">
        <!-- Card 1: Ideapreneur -->
        <div class="bg-slate-800/50 backdrop-blur-md border border-white/10 p-10 rounded-xl flex flex-col h-full" data-ps="src/pages/our-programs.astro:x1jwq8-idea">
          <h3 class="text-[24px] font-bold text-[#FFFFFF] mb-6 text-left" data-ps="src/pages/our-programs.astro:2bawft-idea">Ideapreneur</h3>
          <p class="text-[#94A3B8] font-normal leading-relaxed mb-8 flex-grow text-left" data-ps="src/pages/our-programs.astro:77ib3h-idea">
            Backing the "first-believers" at the pure genesis stage. We provide critical first-cheque capital and operational validation for founders with absolute clarity on the problem and solution.
          </p>
          <div class="pt-2 mt-auto" data-ps="src/pages/our-programs.astro:x1jwq9-idea">
            <span class="text-[#00A896] font-bold text-sm block" data-ps="src/pages/our-programs.astro:ed2cbu-idea">Investment Stage: First Cheque / Idea Stage
<br/>Funding: 5-25 Lakhs first cheque</span>
          </div>
        </div>

        <!-- Card 2: Solopreneur -->
        <div class="bg-slate-800/50 backdrop-blur-md border border-white/10 p-10 rounded-xl flex flex-col h-full" data-ps="src/pages/our-programs.astro:lui32j">
          <h3 class="text-[24px] font-bold text-[#FFFFFF] mb-6 text-left" data-ps="src/pages/our-programs.astro:2bawfr">Solopreneur</h3>
          <p class="text-[#94A3B8] font-normal leading-relaxed mb-8 flex-grow text-left" data-ps="src/pages/our-programs.astro:77ib3j">
            Our nuanced understanding of the solo startup landscape ensures tailored guidance. We extend our hand with strategic investments, acting as a dedicated partner in your journey.
          </p>
          <div class="pt-2 mt-auto" data-ps="src/pages/our-programs.astro:lui32i">
            <span class="text-[#00A896] font-bold text-sm block" data-ps="src/pages/our-programs.astro:ed2cbw">Investment Stage: First Institutional Cheque
<br/>Funding: 10-50 Lakhs</span>
          </div>
        </div>

        <!-- Card 3: Entrepreneur -->
        <div class="bg-slate-800/50 backdrop-blur-md border border-white/10 p-10 rounded-xl flex flex-col h-full" data-ps="src/pages/our-programs.astro:x1jwqa-entrepreneur">
          <h3 class="text-[24px] font-bold text-[#FFFFFF] mb-6 text-left" data-ps="src/pages/our-programs.astro:2bawfs-entrepreneur">Entrepreneur</h3>
          <p class="text-[#94A3B8] font-normal leading-relaxed mb-8 flex-grow text-left" data-ps="src/pages/our-programs.astro:77ib3i-entrepreneur">
            Beyond capital infusion, we provide a robust network and valuable resources. Through mentorship and operational support, SPVH becomes a catalyst for sustained growth.
          </p>
          <div class="pt-2 mt-auto" data-ps="src/pages/our-programs.astro:x1jwqb-entrepreneur">
            <span class="text-[#00A896] font-bold text-sm block" data-ps="src/pages/our-programs.astro:ed2cbv-entrepreneur">Investment Stage: Venture Round
<br/>Funding: 1 Crore & Above</span>
          </div>
        </div>

        <!-- Card 4: Familypreneur -->
        <div class="bg-slate-800/50 backdrop-blur-md border border-white/10 p-10 rounded-xl flex flex-col h-full" data-ps="src/pages/our-programs.astro:x1jwq8-family">
          <h3 class="text-[24px] font-bold text-[#FFFFFF] mb-6 text-left" data-ps="src/pages/our-programs.astro:2bawft-family">Familypreneur</h3>
          <p class="text-[#94A3B8] font-normal leading-relaxed mb-8 flex-grow text-left" data-ps="src/pages/our-programs.astro:77ib3h-family">
            We understand the unique strengths of family businesses. Our approach preserves your vitality, values, and culture, ensuring your family's history is kept intact.
          </p>
          <div class="pt-2 mt-auto" data-ps="src/pages/our-programs.astro:x1jwq9-family">
            <span class="text-[#00A896] font-bold text-sm block" data-ps="src/pages/our-programs.astro:ed2cbu-family">Investment Stage: Flexible tailored structures
<br/>Funding: 25 Lakhs & Above</span>
          </div>
        </div>
      </div>

      <!-- Call to Action Button -->
      <div class="flex flex-col sm:flex-row justify-center items-stretch sm:items-center gap-4 sm:gap-6 mt-12 max-w-md sm:max-w-none mx-auto" data-ps="src/pages/our-programs.astro:lui32a">
        <a href="/#contact" class="bg-[#00A896] hover:bg-[#00A896]/90 text-white font-bold py-3 px-6 sm:px-8 rounded-lg uppercase tracking-wide transition-all text-sm sm:text-base text-center whitespace-nowrap" data-ps="src/pages/our-programs.astro:ytxu8t">Apply Now</a>
        <button id="open-deck-modal" class="bg-transparent border-2 border-[#00A896] hover:bg-[#00A896]/10 text-white font-bold py-3 px-6 sm:px-8 rounded-lg uppercase tracking-wide transition-all cursor-pointer text-sm sm:text-base text-center whitespace-nowrap" data-ps="src/pages/our-programs.astro:download-deck">Access Program Deck</button>
      </div>
    </div>
  </section>

  <!-- Section 4: Value Creation Ecosystem (1x4 Premium Layout) -->
  <section class="py-24 bg-[#F8FAFC] relative overflow-hidden" data-ps="src/pages/our-programs.astro:koto0o">
    <!-- Subtle Geometric Pattern -->
    <div class="absolute inset-0 opacity-[0.4] pointer-events-none" style="background-image: radial-gradient(#CBD5E1 0.5px, transparent 0.5px); background-size: 32px 32px;" data-ps="src/pages/our-programs.astro:pattern-bg"></div>
    
    <div class="w-full max-w-[1440px] mx-auto px-4 lg:px-8 relative z-10" data-ps="src/pages/our-programs.astro:x1jwpf">
      <div class="text-center mb-16" data-ps="src/pages/our-programs.astro:x1jwpg">
        <span class="text-[#00A896] font-bold uppercase tracking-[0.2em] text-sm block mb-4" data-ps="src/pages/our-programs.astro:section-label">BEYOND CAPITAL</span>
        <h2 class="text-3xl md:text-5xl font-bold text-[#1B202D] tracking-tight mb-6" data-ps="src/pages/our-programs.astro:cd40rv">The SPVH Value Creation Ecosystem</h2>
        <p class="text-lg text-[#475569] mx-auto leading-relaxed" data-ps="src/pages/our-programs.astro:77ib3g">
          We provide the foundation for sustained success through a highly structured ecosystem of operational expertise and strategic leverage.
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8" data-ps="src/pages/our-programs.astro:x1jwq2">
        <!-- Card 01 -->
        <div class="bg-white p-10 rounded-2xl border border-[#E2E8F0] shadow-sm hover:shadow-xl transition-all relative overflow-hidden flex flex-col h-full group" data-ps="src/pages/our-programs.astro:x1jwq3-0">
          <div class="absolute right-6 top-6 text-7xl font-bold text-[#E2E8F0]/40 select-none z-0" data-ps="src/pages/our-programs.astro:numeral-01">01</div>
          <div class="relative z-10 h-full flex flex-col" data-ps="src/pages/our-programs.astro:lui32d">
            <div class="w-12 h-12 flex items-center justify-center mb-8" data-ps="src/pages/our-programs.astro:icon-01">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#00A896" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-trending-up"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"></polyline><polyline points="16 7 22 7 22 13"></polyline></svg>
            </div>
            <div class="min-h-[60px]" data-ps="src/pages/our-programs.astro:h3-container-01">
              <h3 class="text-xl font-bold text-[#1B202D] mb-4 leading-tight" data-ps="src/pages/our-programs.astro:2bawfu-0">Capital & Financial Structuring</h3>
            </div>
            <p class="text-[#475569] leading-[1.6] text-[15px]" data-ps="src/pages/our-programs.astro:desc-01">
              Beyond initial capital injection, we provide dynamic financial modeling, follow-on syndication, and optimized capital structuring to ensure sustained liquidity and efficient growth.
            </p>
          </div>
        </div>

        <!-- Card 02 -->
        <div class="bg-white p-10 rounded-2xl border border-[#E2E8F0] shadow-sm hover:shadow-xl transition-all relative overflow-hidden flex flex-col h-full group" data-ps="src/pages/our-programs.astro:x1jwq3-1">
          <div class="absolute right-6 top-6 text-7xl font-bold text-[#E2E8F0]/40 select-none z-0" data-ps="src/pages/our-programs.astro:numeral-02">02</div>
          <div class="relative z-10 h-full flex flex-col" data-ps="src/pages/our-programs.astro:lui32c">
            <div class="w-12 h-12 flex items-center justify-center mb-8" data-ps="src/pages/our-programs.astro:icon-02">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#00A896" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-compass"><circle cx="12" cy="12" r="10"></circle><polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"></polygon></svg>
            </div>
            <div class="min-h-[60px]" data-ps="src/pages/our-programs.astro:h3-container-02">
              <h3 class="text-xl font-bold text-[#1B202D] mb-4 leading-tight" data-ps="src/pages/our-programs.astro:2bawfu-1">Strategic Advisory & Governance</h3>
            </div>
            <p class="text-[#475569] leading-[1.6] text-[15px]" data-ps="src/pages/our-programs.astro:desc-02">
              Our partners gain direct access to seasoned executives and industry veterans, offering high-level strategic guidance, board-level governance structuring, and leadership mentorship.
            </p>
          </div>
        </div>

        <!-- Card 03 -->
        <div class="bg-white p-10 rounded-2xl border border-[#E2E8F0] shadow-sm hover:shadow-xl transition-all relative overflow-hidden flex flex-col h-full group" data-ps="src/pages/our-programs.astro:x1jwq3-2">
          <div class="absolute right-6 top-6 text-7xl font-bold text-[#E2E8F0]/40 select-none z-0" data-ps="src/pages/our-programs.astro:numeral-03">03</div>
          <div class="relative z-10 h-full flex flex-col" data-ps="src/pages/our-programs.astro:lui32b">
            <div class="w-12 h-12 flex items-center justify-center mb-8" data-ps="src/pages/our-programs.astro:icon-03">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#00A896" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-settings"><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.1a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"></path><circle cx="12" cy="12" r="3"></circle></svg>
            </div>
