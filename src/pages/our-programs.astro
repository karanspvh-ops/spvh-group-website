  <script>
    import 'altcha';

    const modal = document.getElementById('deck-modal');
    const openBtn = document.getElementById('open-deck-modal');
    const closeBtn = document.getElementById('close-modal');
    const backdrop = document.getElementById('modal-backdrop');
    const form = document.getElementById('deck-form') as HTMLFormElement;
    const formContainer = document.getElementById('form-container');
    const successContainer = document.getElementById('success-container');

    const DECK_URL = '/files/Curriculum-Securities-or-financial-assets-wef-01072022.pdf';

    function openModal() {
      modal?.classList.remove('hidden');
      modal?.classList.add('flex');
      document.body.style.overflow = 'hidden';
    }

    function closeModal() {
      modal?.classList.add('hidden');
      modal?.classList.remove('flex');
      document.body.style.overflow = '';
      // Reset state if needed after closing
      if (successContainer?.classList.contains('flex')) {
         setTimeout(() => {
           formContainer?.classList.remove('hidden');
           successContainer?.classList.add('hidden');
           successContainer?.classList.remove('flex');
           form.reset();
         }, 300);
      }
    }

    openBtn?.addEventListener('click', openModal);
    closeBtn?.addEventListener('click', closeModal);
    backdrop?.addEventListener('click', closeModal);

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = new FormData(form);
      const data = Object.fromEntries(formData);

      try {
        const response = await fetch('/psapi-internal-v1/forms/submit', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            ...data,
            subject: 'New Program Deck Request',
            altcha: formData.get('altcha')
          })
        });

        if (response.ok) {
          // Success State
          formContainer?.classList.add('hidden');
          successContainer?.classList.remove('hidden');
          successContainer?.classList.add('flex');

          // Trigger Download
          const link = document.createElement('a');
          link.href = DECK_URL;
          link.setAttribute('download', 'Curriculum-Securities-or-financial-assets-wef-01072022.pdf');
          link.setAttribute('target', '_blank'); // Ensures reliable behavior for external CDN links
          document.body.appendChild(link);
          link.click();
          document.body.removeChild(link);
        }
      } catch (err) {
        console.error('Submission error:', err);
        alert('There was an error submitting the form. Please try again.');
      }
    });
  </script>

