---
import BaseLayout from '@/layouts/BaseLayout.astro';
import VerticalNav from '@/components/VerticalNav.astro';
import { SITE } from '@/config/site';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": `Media & Entertainment | ${SITE.name}`,
  "description": "Whatever Productions: An independent, full-service production house based in Mumbai shaping the Indian cinematic landscape.",
  "url": `${SITE.url}media-entertainment`
};
---

<BaseLayout title={`Media & Entertainment | ${SITE.name}`} description="Whatever Productions: Shaping the Indian cinematic landscape with compelling narratives and striking visuals." jsonLd={jsonLd}>
  <!-- Section 1: Vertical Hero & Overview -->
  <section class="relative min-h-[90vh] flex items-center pt-20 overflow-hidden bg-dark" data-ps="src/pages/media-entertainment.astro:ij18y2">
    <div class="absolute inset-0 z-0" data-ps="src/pages/media-entertainment.astro:u75sk2">
      <img 
        src="https://images.unsplash.com/photo-1556912300-3017f3de2aa6?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w4MTQzNzh8MHwxfHNlYXJjaHwyMHx8Q2luZW1hdGljJTIwcHJvZHVjdGlvbiUyMGJhY2tncm91bmR8ZW58MHx8fHwxNzc1ODE4MDYxfDA&ixlib=rb-4.1.0&q=80&w=1200&auto=format"
        sizes="100vw"
        alt="Cinematic production background" 
        class="w-full h-full object-cover opacity-60"
        loading="eager"
        fetchpriority="high" data-ps="src/pages/media-entertainment.astro:rowo7w" crossorigin="anonymous" />
      <div class="absolute inset-0 bg-gradient-to-r from-dark via-dark/40 to-transparent" data-ps="src/pages/media-entertainment.astro:u75sk3"></div>
    </div>

    <div class="container mx-auto px-6 relative z-10" data-ps="src/pages/media-entertainment.astro:u75sk4">
      <div class="max-w-3xl hero-animate" data-ps="src/pages/media-entertainment.astro:u75sk5">
        <a href="/#businesses" class="inline-block px-4 py-1 rounded-full bg-primary/20 backdrop-blur-md border border-primary/30 text-white text-sm font-bold uppercase tracking-widest mb-6 hover:bg-primary/40 transition-colors cursor-pointer" data-ps="src/pages/media-entertainment.astro:jrg8pf">Business Vertical</a>
        <h1 class="text-5xl md:text-7xl font-bold text-white mb-8 leading-[1.1]" data-ps="src/pages/media-entertainment.astro:we8sx">
          <span class="text-primary uppercase flex flex-col justify-end min-h-[2.2em]" data-ps="src/pages/media-entertainment.astro:9swegu">
            <span data-ps="src/pages/media-entertainment.astro:9swegu">MEDIA &</span>
            <span data-ps="src/pages/media-entertainment.astro:9swegt">ENTERTAINMENT</span>
          </span>
        </h1>
        <div class="bg-white/10 backdrop-blur-xl border border-white/20 p-8 rounded-2xl shadow-2xl" data-ps="src/pages/media-entertainment.astro:zcdrff">
          <p class="text-xl text-dark-muted leading-relaxed" data-ps="src/pages/media-entertainment.astro:e17nsb">
            Our Media & Entertainment division is an independent, full-service production house based in Mumbai. We are dedicated to shaping the Indian cinematic landscape by transforming compelling concepts into borderless stories. Unlike traditional production models, our DNA is rooted in an organized, ethical, and highly transparent work culture. From full-length theatrical features to digital OTT formats, our in-house network manages the entire lifecycle of filmmaking—from pre-production and talent management to strategic digital marketing and global distribution.
          </p>
        </div>
      </div>
    </div>
  </section>

  <VerticalNav activePath="/media-entertainment" />

  <!-- Section: Strategic Engine & Core Capabilities -->
  <section class="relative pt-20 pb-16 bg-surface overflow-hidden" data-ps="src/pages/media-entertainment.astro:strategic-engine">
    <!-- Background Art / Pattern -->
    <div class="absolute inset-0 z-0 pointer-events-none" data-ps="src/pages/media-entertainment.astro:intro-bg-art">
      <img 
        src="/images/SPVH-Patterns-2-1536.webp" 
        alt="Geometric pattern background" 
        class="w-full h-full object-cover opacity-10" data-ps="src/pages/media-entertainment.astro:pattern-bg" />
      <div class="absolute inset-0 bg-gradient-to-b from-surface via-transparent to-surface" data-ps="src/pages/media-entertainment.astro:pattern-overlay"></div>
    </div>
    
    <div class="container mx-auto px-6 max-w-[900px] text-center relative z-10" data-ps="src/pages/media-entertainment.astro:strategic-container">
      <h2 class="text-3xl md:text-4xl font-bold text-[#496bad] mb-6" data-ps="src/pages/media-entertainment.astro:strategic-h2">
        Strategic Investments in Global Content
      </h2>
      <p class="text-lg md:text-[20px] text-[#00A896] leading-[1.6] font-medium italic" data-ps="src/pages/media-entertainment.astro:strategic-p1">
        "Capitalizing on the rapid evolution of global content consumption, we build scalable, high-yield media assets that shape cultural narratives and deliver exceptional risk-adjusted returns."
      </p>
    </div>
  </section>



  <!-- Section: Our Philosophy (Institutional Remodel) -->
  <section class="py-24 bg-[#0A1931]" data-ps="src/pages/media-entertainment.astro:philosophy-section">
    <div class="container px-6 mx-auto max-w-[1400px]" data-ps="src/pages/media-entertainment.astro:philosophy-container">
      <div class="text-center max-w-4xl mx-auto mb-20" data-ps="src/pages/media-entertainment.astro:philosophy-header">
        <span class="block text-[#00A896] text-sm font-bold uppercase tracking-[0.2em] mb-4" data-ps="src/pages/media-entertainment.astro:philosophy-kicker">OUR PHILOSOPHY</span>
        <h2 class="text-4xl md:text-5xl font-bold text-white leading-tight" data-ps="src/pages/media-entertainment.astro:philosophy-h2">
          Shaping Narratives. Scaling Global Influence.
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8" data-ps="src/pages/media-entertainment.astro:philosophy-grid">
        <!-- Card 1: Narrative Excellence -->
        <div class="bg-[#14223a] border border-[#496bad] p-[30px] rounded-[12px] flex flex-col h-full text-center" data-ps="src/pages/media-entertainment.astro:phil-card-1">
          <div class="h-[70px] flex items-center justify-center mb-6" data-ps="src/pages/media-entertainment.astro:phil-title-container-1">
            <h3 class="text-[22px] font-bold text-[#00A896]" data-ps="src/pages/media-entertainment.astro:phil-title-1">Narrative Excellence</h3>
          </div>
          <div class="h-[120px] flex items-start justify-center" data-ps="src/pages/media-entertainment.astro:phil-body-container-1">
            <p class="text-[#D1D1D1] leading-[1.5] font-normal" data-ps="src/pages/media-entertainment.astro:phil-text-1">
              We prioritize content with profound cultural resonance, investing in high-caliber storytelling that shapes global narratives and builds lasting IP value.
            </p>
          </div>
        </div>

        <!-- Card 2: Commercial Viability -->
        <div class="bg-[#14223a] border border-[#496bad] p-[30px] rounded-[12px] flex flex-col h-full text-center" data-ps="src/pages/media-entertainment.astro:phil-card-2">
          <div class="h-[70px] flex items-center justify-center mb-6" data-ps="src/pages/media-entertainment.astro:phil-title-container-2">
            <h3 class="text-[22px] font-bold text-[#00A896]" data-ps="src/pages/media-entertainment.astro:phil-title-2">Commercial Viability</h3>
          </div>
          <div class="h-[120px] flex items-start justify-center" data-ps="src/pages/media-entertainment.astro:phil-body-container-2">
            <p class="text-[#D1D1D1] leading-[1.5] font-normal" data-ps="src/pages/media-entertainment.astro:phil-text-2">
              Every project is evaluated through a rigorous commercial lens, ensuring high-yield potential and scalability across diverse global consumption markets.
            </p>
          </div>
        </div>

        <!-- Card 3: Intellectual Property -->
        <div class="bg-[#14223a] border border-[#496bad] p-[30px] rounded-[12px] flex flex-col h-full text-center" data-ps="src/pages/media-entertainment.astro:phil-card-3">
          <div class="h-[70px] flex items-center justify-center mb-6" data-ps="src/pages/media-entertainment.astro:phil-title-container-3">
            <h3 class="text-[22px] font-bold text-[#00A896]" data-ps="src/pages/media-entertainment.astro:phil-title-3">Intellectual Property</h3>
          </div>
          <div class="h-[120px] flex items-start justify-center" data-ps="src/pages/media-entertainment.astro:phil-body-container-3">
            <p class="text-[#D1D1D1] leading-[1.5] font-normal" data-ps="src/pages/media-entertainment.astro:phil-text-3">
              We focus on the acquisition and development of resilient IP, leveraging strategic distribution and multi-platform monetization to maximize capital returns.
            </p>
          </div>
        </div>

        <!-- Card 4: Scalable Innovation -->
        <div class="bg-[#14223a] border border-[#496bad] p-[30px] rounded-[12px] flex flex-col h-full text-center" data-ps="src/pages/media-entertainment.astro:phil-card-4">
          <div class="h-[70px] flex items-center justify-center mb-6" data-ps="src/pages/media-entertainment.astro:phil-title-container-4">
            <h3 class="text-[22px] font-bold text-[#00A896]" data-ps="src/pages/media-entertainment.astro:phil-title-4">Scalable Innovation</h3>
          </div>
          <div class="h-[120px] flex items-start justify-center" data-ps="src/pages/media-entertainment.astro:phil-body-container-4">
            <p class="text-[#D1D1D1] leading-[1.5] font-normal" data-ps="src/pages/media-entertainment.astro:phil-text-4">
              We integrate advanced digital frameworks and production technologies to optimize content delivery, reduce risk, and enhance audience engagement worldwide.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="relative py-32 bg-dark overflow-hidden" data-ps="src/pages/media-entertainment.astro:capabilities-section">
    <!-- Cinematic Background -->
    <div class="absolute inset-0 z-0" data-ps="src/pages/media-entertainment.astro:capabilities-bg">
      <img 
        src="/images/national-museum-of-indian-cinema-mumbai-maharashtra-1-musthead-hero-1024.webp"
        sizes="100vw"
        alt="Cinematic media production background" 
        class="w-full h-full object-cover object-center"
        loading="lazy" data-ps="src/pages/media-entertainment.astro:cap-bg-img" />
      <div class="absolute inset-0 bg-black/20" data-ps="src/pages/media-entertainment.astro:cap-bg-overlay"></div>
    </div>

    <div class="container px-6 mx-auto max-w-[1400px] relative z-10" data-ps="src/pages/media-entertainment.astro:capabilities-container">
      <div class="text-center mb-16" data-ps="src/pages/media-entertainment.astro:capabilities-header">
        <h2 class="text-3xl md:text-5xl font-bold text-white drop-shadow-md" data-ps="src/pages/media-entertainment.astro:strategic-h3">Media Ecosystem</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8" data-ps="src/pages/media-entertainment.astro:capabilities-list">
        <!-- Card 1: Feature Films & Digital Media -->
        <div class="bg-white/25 backdrop-blur-[12px] rounded-2xl overflow-hidden shadow-[0_8px_32px_rgba(0,0,0,0.15)] border border-white/40 p-10 flex flex-col text-center" data-ps="src/pages/media-entertainment.astro:cap-card-1">
          <div class="text-[#496bad] mb-6 flex justify-center" data-ps="src/pages/media-entertainment.astro:cap-icon-1">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="2.18" ry="2.18"/><line x1="7" y1="2" x2="7" y2="22"/><line x1="17" y1="2" x2="17" y2="22"/><line x1="2" y1="12" x2="22" y2="12"/><line x1="2" y1="7" x2="7" y2="7"/><line x1="2" y1="17" x2="7" y2="17"/><line x1="17" y1="17" x2="22" y2="17"/><line x1="17" y1="7" x2="22" y2="7"/></svg>
          </div>
          <h3 class="text-[22px] font-bold text-[#0A1931] mb-4 leading-tight" data-ps="src/pages/media-entertainment.astro:cap-title-1">Feature Films & Web Shows</h3>
          <p class="text-[#0A1931] text-base leading-[1.5] font-normal" data-ps="src/pages/media-entertainment.astro:cap-text-1">
            Financing and producing high-caliber cinematic and digital content. We back visionary creators to deliver commercially viable, globally scalable stories that resonate across multi-platform distribution networks.
          </p>
        </div>

        <!-- Card 2: Live Entertainment & Concerts -->
        <div class="bg-white/25 backdrop-blur-[12px] rounded-2xl overflow-hidden shadow-[0_8px_32px_rgba(0,0,0,0.15)] border border-white/40 p-10 flex flex-col text-center" data-ps="src/pages/media-entertainment.astro:cap-card-2">
          <div class="text-[#496bad] mb-6 flex justify-center" data-ps="src/pages/media-entertainment.astro:cap-icon-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 9a3 3 0 0 1 0 6v2a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-2a3 3 0 0 1 0-6V7a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2Z"/><path d="M13 5v2"/><path d="M13 11v2"/><path d="M13 17v2"/></svg>
          </div>
          <h3 class="text-[22px] font-bold text-[#0A1931] mb-4 leading-tight" data-ps="src/pages/media-entertainment.astro:cap-title-2">Live Entertainment & Concerts</h3>
          <p class="text-[#0A1931] text-base leading-[1.5] font-normal" data-ps="src/pages/media-entertainment.astro:cap-text-2">
            Strategically backing large-scale live entertainment properties and experiential ventures. We merge innovative event architecture with high-value partnerships to drive immersive consumer experiences and high-margin returns.
          </p>
        </div>

        <!-- Card 3: Ad Films & Series -->
        <div class="bg-white/25 backdrop-blur-[12px] rounded-2xl overflow-hidden shadow-[0_8px_32px_rgba(0,0,0,0.15)] border border-white/40 p-10 flex flex-col text-center" data-ps="src/pages/media-entertainment.astro:cap-card-3">
          <div class="text-[#496bad] mb-6 flex justify-center" data-ps="src/pages/media-entertainment.astro:cap-icon-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
          </div>
          <h3 class="text-[22px] font-bold text-[#0A1931] mb-4 leading-tight" data-ps="src/pages/media-entertainment.astro:cap-title-3">Ad Films & Commercials</h3>
          <p class="text-[#0A1931] text-base leading-[1.5] font-normal" data-ps="src/pages/media-entertainment.astro:cap-text-3">
            Capitalizing on short-form storytelling and brand narratives. We invest in premium commercial productions and episodic series that offer rapid production cycles, strong brand synergies, and highly predictable revenue streams.
          </p>
        </div>

        <!-- Card 4: IP Acquisition & Consolidation -->
        <div class="bg-white/25 backdrop-blur-[12px] rounded-2xl overflow-hidden shadow-[0_8px_32px_rgba(0,0,0,0.15)] border border-white/40 p-10 flex flex-col text-center" data-ps="src/pages/media-entertainment.astro:cap-card-4">
          <div class="text-[#496bad] mb-6 flex justify-center" data-ps="src/pages/media-entertainment.astro:cap-icon-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z"/><path d="m9 12 2 2 4-4"/></svg>
          </div>
          <h3 class="text-[22px] font-bold text-[#0A1931] mb-4 leading-tight" data-ps="src/pages/media-entertainment.astro:cap-title-4">IP Acquisition & Consolidation</h3>
          <p class="text-[#0A1931] text-base leading-[1.5] font-normal" data-ps="src/pages/media-entertainment.astro:cap-text-4">
            Focused on the strategic acquisition and development of resilient intellectual property. We build robust asset libraries, leveraging cross-platform monetization and strategic consolidation to maximize long-term capital returns.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Section: Complete Production Ecosystem -->
  <section class="py-24 bg-white" data-ps="src/pages/media-entertainment.astro:ij18y0">
    <div class="container mx-auto px-6 text-center mb-16" data-ps="src/pages/media-entertainment.astro:u75skx">
      <h2 class="text-3xl md:text-4xl font-bold text-dark mb-4" data-ps="src/pages/media-entertainment.astro:fkt60j">Our Production Services</h2>
      <div class="w-20 h-1.5 bg-secondary mx-auto rounded-full" data-ps="src/pages/media-entertainment.astro:u75sky"></div>
    </div>

    <div class="container mx-auto px-6" data-ps="src/pages/media-entertainment.astro:u75skz">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8" data-ps="src/pages/media-entertainment.astro:u75sl0">
        <!-- Item 1 -->
        <div class="p-8 text-center border border-border rounded-2xl hover:border-primary/30 hover:shadow-xl hover:shadow-primary/5 transition-all duration-300" data-ps="src/pages/media-entertainment.astro:u75sl1">
          <div class="w-16 h-16 bg-primary/10 rounded-xl flex items-center justify-center mx-auto mb-6 text-[#496bad]" data-ps="src/pages/media-entertainment.astro:u75sl2">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="12" rx="2" ry="2"></rect><path d="M2 8h20"></path><path d="M6 4v4"></path><path d="M10 4v4"></path><path d="M14 4v4"></path><path d="M18 4v4"></path></svg>
          </div>
          <h3 class="text-xl font-bold text-dark mb-2" data-ps="src/pages/media-entertainment.astro:u98389">Line Production</h3>
        </div>

        <!-- Item 2 -->
        <div class="p-8 text-center border border-border rounded-2xl hover:border-primary/30 hover:shadow-xl hover:shadow-primary/5 transition-all duration-300" data-ps="src/pages/media-entertainment.astro:zcdrf6">
          <div class="w-16 h-16 bg-primary/10 rounded-xl flex items-center justify-center mx-auto mb-6 text-[#496bad]" data-ps="src/pages/media-entertainment.astro:zcdrf7">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
          </div>
          <h3 class="text-xl font-bold text-dark mb-2" data-ps="src/pages/media-entertainment.astro:u98388">Co-Production Services</h3>
        </div>

        <!-- Item 3 -->
        <div class="p-8 text-center border border-border rounded-2xl hover:border-primary/30 hover:shadow-xl hover:shadow-primary/5 transition-all duration-300" data-ps="src/pages/media-entertainment.astro:zcdrf8">
          <div class="w-16 h-16 bg-primary/10 rounded-xl flex items-center justify-center mx-auto mb-6 text-primary" data-ps="src/pages/media-entertainment.astro:zcdrf9">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" x2="12" y1="2" y2="22"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
          </div>
          <h3 class="text-xl font-bold text-dark mb-2" data-ps="src/pages/media-entertainment.astro:u98387">Film Financing</h3>
        </div>

        <!-- Item 4 -->
        <div class="p-8 text-center border border-border rounded-2xl hover:border-primary/30 hover:shadow-xl hover:shadow-primary/5 transition-all duration-300" data-ps="src/pages/media-entertainment.astro:zcdrfa">
          <div class="w-16 h-16 bg-primary/10 rounded-xl flex items-center justify-center mx-auto mb-6 text-primary" data-ps="src/pages/media-entertainment.astro:zcdrfb">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" x2="22" y1="12" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
          </div>
          <h3 class="text-xl font-bold text-dark mb-2" data-ps="src/pages/media-entertainment.astro:u98386">Selling & Distribution</h3>
        </div>
      </div>
    </div>
  </section>







  <!-- Section 4: Call to Action (High-Impact CTA Banner) -->
  <section class="relative py-24 bg-[#0A1931] overflow-hidden" data-ps="src/pages/media-entertainment.astro:ij18xz">
    <!-- Texture Overlay -->
    <div class="absolute inset-0 z-0 pointer-events-none opacity-5" data-ps="src/pages/media-entertainment.astro:cta-texture">
      <img 
        src="/images/SPVH-Patterns-2-1536.webp" 
        alt="Background pattern" 
        class="w-full h-full object-cover" data-ps="src/pages/media-entertainment.astro:cta-pattern-img" />
    </div>

    <div class="container mx-auto px-6 text-center relative z-10" data-ps="src/pages/media-entertainment.astro:zcdrfc">
      <div class="max-w-[1200px] mx-auto" data-ps="src/pages/media-entertainment.astro:cta-content-wrapper">
        <span class="block text-sm font-bold tracking-[0.3em] text-[#00A896] uppercase mb-6" data-ps="src/pages/media-entertainment.astro:cta-kicker">PARTNER WITH US</span>
        
        <h2 class="text-3xl md:text-5xl lg:text-6xl xl:text-7xl font-bold text-white mb-8 leading-tight tracking-tight lg:whitespace-nowrap" data-ps="src/pages/media-entertainment.astro:fkt60i">
          Ready to Shape the Future of <span class="text-[#00A896]" data-ps="src/pages/media-entertainment.astro:9swegw">Global Content?</span>
        </h2>
        
        <p class="text-xl text-[#D1D1D1] mb-12 w-full lg:max-w-none mx-auto text-center leading-relaxed lg:whitespace-nowrap" data-ps="src/pages/media-entertainment.astro:cta-subheadline">
          Speak with our media investment team today. Explore high-yield opportunities in IP and entertainment.
        </p>

        <!-- Inactive Buttons -->
        <div class="flex flex-col sm:flex-row items-center justify-center gap-5 mb-16" data-ps="src/pages/media-entertainment.astro:cta-buttons">
