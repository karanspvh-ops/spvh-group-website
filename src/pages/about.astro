---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Founder from '@/components/about/Founder.astro';
import VisionMission from '@/components/about/VisionMission.astro';
import Beliefs from '@/components/about/Beliefs.astro';
import Leadership from '@/components/about/Leadership.astro';
import Alliances from '@/components/about/Alliances.astro';
import AdvisoryBoard from '@/components/about/AdvisoryBoard.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  "name": "About SPVH Group",
  "description": "Learn about SPVH Group, our founder Sujay Prakash, our vision, mission, and leadership team.",
  "url": Astro.site?.toString() + "about"
};
---

<BaseLayout 
  title="About SPVH Group | Institutional Grade Asset Management" 
  description="Discover the vision, mission, and leadership driving SPVH Group's institutional grade asset management and wealth creation."
>
  <div class="pt-[var(--nav-height)] bg-surface" data-ps="src/pages/about.astro:8d132o">
    <Founder />
    <VisionMission />
    <Beliefs />
    <Leadership />
    <Alliances />
    <AdvisoryBoard />
  </div>
</BaseLayout>
