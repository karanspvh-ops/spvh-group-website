---
import BaseLayout from '@/layouts/BaseLayout.astro';
import VerticalNav from '@/components/VerticalNav.astro';
import { SITE } from '@/config/site';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Real Estate & Interior Design | SPVH Group",
  "description": "Bespoke Real Estate and Interior Design solutions for commercial infrastructure, luxury hospitality, and corporate environments.",
  "url": `${SITE.url}verticals/real-estate-interior-design`
};
---

<BaseLayout title="Real Estate & Interior Design | SPVH Group" description="Architecting Excellence in Real Estate and Interior Design." jsonLd={jsonLd}>
  <!-- Hero Section -->
  <section class="relative min-h-[90vh] flex items-center pt-20 overflow-hidden bg-dark" data-ps="src/pages/verticals/real-estate-interior-design.astro:hm2wr3">
    <div class="absolute inset-0 z-0" data-ps="src/pages/verticals/real-estate-interior-design.astro:s0yudy">
      <img 
        src="https://images.unsplash.com/photo-1582407947304-fd86f028f716?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w4MTQzNzh8MHwxfHNlYXJjaHwxfHxyZWFsJTIwZXN0YXRlfGVufDB8fHx8MTc3NTgxODkzN3ww&ixlib=rb-4.1.0&q=80&w=1200&auto=format"
        sizes="100vw"
        alt="Modern luxury architectural interior" 
        class="w-full h-full object-cover opacity-60"
        loading="eager"
        fetchpriority="high" data-ps="src/pages/verticals/real-estate-interior-design.astro:uj7yq4" crossorigin="anonymous" />
      <div class="absolute inset-0 bg-gradient-to-r from-dark via-dark/40 to-transparent" data-ps="src/pages/verticals/real-estate-interior-design.astro:s0yudx"></div>
    </div>

    <div class="container mx-auto px-6 relative z-10" data-ps="src/pages/verticals/real-estate-interior-design.astro:s0yudw">
      <div class="max-w-3xl hero-animate" data-ps="src/pages/verticals/real-estate-interior-design.astro:s0yudv">
        <a href="/#businesses" class="inline-block px-4 py-1 rounded-full bg-primary/20 backdrop-blur-md border border-primary/30 text-white text-sm font-bold uppercase tracking-widest mb-6 hover:bg-primary/40 transition-colors cursor-pointer" data-ps="src/pages/verticals/real-estate-interior-design.astro:s0yudu">Business Vertical</a>
        <h1 class="text-5xl md:text-7xl font-bold text-white mb-8 leading-[1.1]" data-ps="src/pages/verticals/real-estate-interior-design.astro:w84rax">
          <span class="text-primary uppercase flex flex-col justify-end min-h-[2.2em]" data-ps="src/pages/verticals/real-estate-interior-design.astro:w019m3">
            <span data-ps="src/pages/verticals/real-estate-interior-design.astro:w019m2">REAL ESTATE &</span>
            <span data-ps="src/pages/verticals/real-estate-interior-design.astro:w019m3">INTERIOR DESIGN</span>
          </span>
          <span class="block mt-4 text-2xl md:text-3xl font-normal text-dark-muted" data-ps="src/pages/verticals/real-estate-interior-design.astro:w019m3">Architecting Excellence.</span>
        </h1>
        <div class="bg-white/10 backdrop-blur-xl border border-white/20 p-8 rounded-2xl shadow-2xl" data-ps="src/pages/verticals/real-estate-interior-design.astro:s0yudt">
          <p class="text-xl text-dark-muted leading-relaxed" data-ps="src/pages/verticals/real-estate-interior-design.astro:6lmx5h">SPVH Group brings an institutional lens to real estate combining rigorous financial structuring with world-class design sensibility to deliver assets that perform and spaces that endure. From land monetization and development financing to luxury turnkey interiors, we partner with landowners, developers, investors, and UHNI clients at every stage of the real estate lifecycle.</p>
        </div>
      </div>
    </div>
  </section>

  <VerticalNav activePath="/verticals/real-estate-interior-design" />

  <!-- Section: Intro Text -->
  <section class="relative pt-20 pb-16 bg-surface overflow-hidden" data-ps="src/pages/verticals/real-estate-interior-design.astro:intro-text-section">
    <!-- Background Art / Pattern -->
    <div class="absolute inset-0 z-0 pointer-events-none" data-ps="src/pages/verticals/real-estate-interior-design.astro:intro-bg-art">
      <img 
        src="https://pagesmith-cdn.com/347b1a00/images/SPVH-Patterns-2-1536.webp" 
        alt="Geometric pattern background" 
        class="w-full h-full object-cover opacity-10" data-ps="src/pages/verticals/real-estate-interior-design.astro:153l89" />
      <div class="absolute inset-0 bg-gradient-to-b from-surface via-transparent to-surface" data-ps="src/pages/verticals/real-estate-interior-design.astro:sq5df0"></div>
    </div>
    
    <div class="container mx-auto px-6 max-w-[1400px] text-center relative z-10" data-ps="src/pages/verticals/real-estate-interior-design.astro:intro-container">
      <h2 class="text-3xl md:text-4xl font-bold text-[#496bad] mb-6" data-ps="src/pages/verticals/real-estate-interior-design.astro:intro-heading">
        Architecting Premium Spatial Assets
      </h2>
      <div class="max-w-6xl mx-auto" data-ps="src/pages/verticals/real-estate-interior-design.astro:intro-quote-container">
        <p class="text-lg md:text-[22px] text-[#00A896] leading-[1.6] font-medium italic" data-ps="src/pages/verticals/real-estate-interior-design.astro:intro-body">"At SPVH Group, our Real Estate & Interior Design division is central to our investment portfolio. We acquire, develop, and custom-design ultra-luxury homes and commercial spaces. By combining rigorous financial planning with visionary design, we use high-end real estate to safely protect and grow our clients' wealth."</p>
      </div>
    </div>
  </section>

  <!-- Section: Our Philosophy -->
  <section class="py-24 bg-[#0A1931] overflow-hidden" data-ps="src/pages/verticals/real-estate-interior-design.astro:philosophy-section-redesign">
    <div class="container px-6 mx-auto max-w-[1400px]" data-ps="src/pages/verticals/real-estate-interior-design.astro:philosophy-container">
      <div class="text-center max-w-4xl mx-auto mb-20" data-ps="src/pages/verticals/real-estate-interior-design.astro:philosophy-header">
        <span class="block text-[#00A896] text-sm font-bold uppercase tracking-[0.2em] mb-4" data-ps="src/pages/verticals/real-estate-interior-design.astro:philosophy-overline">OUR PHILOSOPHY</span>
        <h2 class="text-4xl md:text-5xl font-bold text-white leading-tight" data-ps="src/pages/verticals/real-estate-interior-design.astro:philosophy-tagline">
          Real Estate is Capital. Design is the Multiplier.
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-[1050px] mx-auto" data-ps="src/pages/verticals/real-estate-interior-design.astro:philosophy-grid">
        <!-- Card 1 -->
        <div class="bg-[#14223a] border border-[#496bad] p-[30px] rounded-[12px] flex flex-col h-full text-center" data-ps="src/pages/verticals/real-estate-interior-design.astro:phil-card-1">
          <div class="h-[70px] flex items-center justify-center mb-6" data-ps="src/pages/verticals/real-estate-interior-design.astro:phil-icon-1">
            <h3 class="text-[22px] font-bold text-[#00A896]" data-ps="src/pages/verticals/real-estate-interior-design.astro:phil-title-1">Capital Discipline at Every Stage</h3>
          </div>
          <div class="h-[120px] flex items-start justify-center" data-ps="src/pages/verticals/real-estate-interior-design.astro:phil-body-1-container">
            <p class="text-[#D1D1D1] leading-[1.5] font-normal" data-ps="src/pages/verticals/real-estate-interior-design.astro:phil-body-1">
              Every real estate engagement begins with financial rigor viability analysis, costing assessment, and return modelling before a single design decision is made. We ensure that aesthetics and economics work in unison, not in tension.
            </p>
          </div>
        </div>

        <!-- Card 2 -->
        <div class="bg-[#14223a] border border-[#496bad] p-[30px] rounded-[12px] flex flex-col h-full text-center" data-ps="src/pages/verticals/real-estate-interior-design.astro:phil-card-2">
          <div class="h-[70px] flex items-center justify-center mb-6" data-ps="src/pages/verticals/real-estate-interior-design.astro:phil-icon-2">
            <h3 class="text-[22px] font-bold text-[#00A896]" data-ps="src/pages/verticals/real-estate-interior-design.astro:phil-title-2">Design as a Value Multiplier</h3>
          </div>
          <div class="h-[120px] flex items-start justify-center" data-ps="src/pages/verticals/real-estate-interior-design.astro:phil-body-2-container">
            <p class="text-[#D1D1D1] leading-[1.5] font-normal" data-ps="src/pages/verticals/real-estate-interior-design.astro:phil-body-2">
              Premium design is not a cost it is a yield driver. We apply sophisticated design thinking, international aesthetic standards, and material excellence to assets that demand a premium, and receive it.
            </p>
          </div>
        </div>

        <!-- Card 3 -->
        <div class="bg-[#14223a] border border-[#496bad] p-[30px] rounded-[12px] flex flex-col h-full text-center" data-ps="src/pages/verticals/real-estate-interior-design.astro:phil-card-3">
          <div class="h-[70px] flex items-center justify-center mb-6" data-ps="src/pages/verticals/real-estate-interior-design.astro:phil-icon-3">
            <h3 class="text-[22px] font-bold text-[#00A896]" data-ps="src/pages/verticals/real-estate-interior-design.astro:phil-title-3">End-to-End Partnership</h3>
          </div>
          <div class="h-[120px] flex items-start justify-center" data-ps="src/pages/verticals/real-estate-interior-design.astro:phil-body-3-container">
            <p class="text-[#D1D1D1] leading-[1.5] font-normal" data-ps="src/pages/verticals/real-estate-interior-design.astro:phil-body-3">
              From land identification and JV structuring to development monitoring and interior delivery, we remain engaged across the full project lifecycle. Our clients do not manage complexity we do.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Section: Real Estate Services (Interactive Tabbed Layout) -->
  <section class="py-24 bg-surface" data-ps="src/pages/verticals/real-estate-interior-design.astro:services-section">
    <div class="container px-6 mx-auto max-w-[1400px]" data-ps="src/pages/verticals/real-estate-interior-design.astro:services-container">
      <!-- Header -->
      <div class="text-center mb-12" data-ps="src/pages/verticals/real-estate-interior-design.astro:services-header">
        <p class="text-[#00A896] font-bold text-sm uppercase tracking-[0.2em] mb-4">REAL ESTATE SERVICES</p>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-dark mb-6">Institutional Advisory Across Every Real Estate Category</h2>
        <p class="text-base md:text-lg text-muted-foreground max-w-3xl mx-auto leading-relaxed">From land monetisation to luxury residential delivery, we provide end-to-end advisory across the entire real estate lifecycle. Select a category to explore our services.</p>
      </div>

      <!-- Category Tabs -->
      <div class="flex flex-wrap items-center justify-center gap-2 md:gap-3 mb-10" id="re-tabs">
        <button data-re-tab="commercial" class="re-tab active flex items-center gap-2 px-5 md:px-7 py-3 rounded-full font-bold uppercase tracking-wider text-xs md:text-sm transition-all duration-300">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="2"/><path d="M9 22v-4h6v4"/><path d="M8 6h.01"/><path d="M16 6h.01"/><path d="M12 6h.01"/><path d="M12 10h.01"/><path d="M12 14h.01"/><path d="M16 10h.01"/><path d="M16 14h.01"/><path d="M8 10h.01"/><path d="M8 14h.01"/></svg>
          Commercial
        </button>
        <button data-re-tab="land" class="re-tab flex items-center gap-2 px-5 md:px-7 py-3 rounded-full font-bold uppercase tracking-wider text-xs md:text-sm transition-all duration-300">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 19h18"/><path d="M5 19v-7l7-5 7 5v7"/><path d="M9 19v-5h6v5"/></svg>
          Land
        </button>
        <button data-re-tab="residential" class="re-tab flex items-center gap-2 px-5 md:px-7 py-3 rounded-full font-bold uppercase tracking-wider text-xs md:text-sm transition-all duration-300">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          Residential
        </button>
      </div>

      <!-- ─── Panel: COMMERCIAL ─── -->
      <div class="re-panel" data-re-panel="commercial">
        <div class="max-w-3xl mx-auto text-center mb-10">
          <p class="text-dark text-base md:text-lg leading-relaxed">We advise developers, investors, and corporates on commercial real estate across office, retail, and mixed-use categories — from early-stage viability through to development monitoring and asset exit.</p>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
          <!-- Viability & Costing -->
          <div class="re-service-card group p-6 rounded-2xl bg-white border border-border hover:border-[#00A896] hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
            <div class="w-12 h-12 rounded-xl bg-[#00A896]/10 text-[#00A896] flex items-center justify-center mb-4 group-hover:bg-[#00A896] group-hover:text-white transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="m19 9-5 5-4-4-3 3"/></svg>
            </div>
            <h4 class="text-dark text-base font-bold mb-2">Viability &amp; Costing Assessment</h4>
            <p class="text-muted-foreground text-sm leading-relaxed">Financial modelling, cost benchmarking, and return analysis to establish project feasibility before commitment.</p>
          </div>
          <!-- Development Financing -->
          <div class="re-service-card group p-6 rounded-2xl bg-white border border-border hover:border-[#00A896] hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
            <div class="w-12 h-12 rounded-xl bg-[#00A896]/10 text-[#00A896] flex items-center justify-center mb-4 group-hover:bg-[#00A896] group-hover:text-white transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" x2="12" y1="2" y2="22"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
            </div>
            <h4 class="text-dark text-base font-bold mb-2">Development Financing</h4>
            <p class="text-muted-foreground text-sm leading-relaxed">Structuring and sourcing of project finance, construction loans, and equity capital for commercial developments.</p>
          </div>
          <!-- JV Partner -->
          <div class="re-service-card group p-6 rounded-2xl bg-white border border-border hover:border-[#00A896] hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
            <div class="w-12 h-12 rounded-xl bg-[#00A896]/10 text-[#00A896] flex items-center justify-center mb-4 group-hover:bg-[#00A896] group-hover:text-white transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            </div>
            <h4 class="text-dark text-base font-bold mb-2">JV Partner Identification</h4>
            <p class="text-muted-foreground text-sm leading-relaxed">Matching landowners and developers with the right equity and operational partners through structured JV frameworks.</p>
          </div>
          <!-- Development Monitoring -->
          <div class="re-service-card group p-6 rounded-2xl bg-white border border-border hover:border-[#00A896] hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
            <div class="w-12 h-12 rounded-xl bg-[#00A896]/10 text-[#00A896] flex items-center justify-center mb-4 group-hover:bg-[#00A896] group-hover:text-white transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>
            </div>
            <h4 class="text-dark text-base font-bold mb-2">Development Monitoring</h4>
            <p class="text-muted-foreground text-sm leading-relaxed">On-ground oversight and milestone-linked progress monitoring for delivery quality, timeline adherence, and cost discipline.</p>
          </div>
          <!-- Leasing & Disposition -->
          <div class="re-service-card group p-6 rounded-2xl bg-white border border-border hover:border-[#00A896] hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
            <div class="w-12 h-12 rounded-xl bg-[#00A896]/10 text-[#00A896] flex items-center justify-center mb-4 group-hover:bg-[#00A896] group-hover:text-white transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/><path d="M16 13H8"/><path d="M16 17H8"/><path d="M10 9H8"/></svg>
            </div>
            <h4 class="text-dark text-base font-bold mb-2">Asset Leasing &amp; Disposition</h4>
            <p class="text-muted-foreground text-sm leading-relaxed">Strategic positioning, leasing advisory, and asset sale execution at optimal pricing and terms.</p>
          </div>
        </div>
      </div>

      <!-- ─── Panel: LAND ─── -->
      <div class="re-panel hidden" data-re-panel="land">
        <div class="max-w-3xl mx-auto text-center mb-10">
          <p class="text-dark text-base md:text-lg leading-relaxed">Land is the foundation of all real estate value. We work with landowners, family estates, and institutional holders to unlock maximum value — through sale, development partnership, or structured monetisation.</p>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
          <!-- Land Viability -->
          <div class="re-service-card group p-6 rounded-2xl bg-white border border-border hover:border-[#00A896] hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
            <div class="w-12 h-12 rounded-xl bg-[#00A896]/10 text-[#00A896] flex items-center justify-center mb-4 group-hover:bg-[#00A896] group-hover:text-white transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="3 6 9 3 15 6 21 3 21 18 15 21 9 18 3 21"/><line x1="9" x2="9" y1="3" y2="18"/><line x1="15" x2="15" y1="6" y2="21"/></svg>
            </div>
            <h4 class="text-dark text-base font-bold mb-2">Land Viability Assessment</h4>
            <p class="text-muted-foreground text-sm leading-relaxed">Zoning, FSI analysis, market comps, and highest-and-best-use evaluation.</p>
          </div>
          <!-- Monetisation Strategy -->
          <div class="re-service-card group p-6 rounded-2xl bg-white border border-border hover:border-[#00A896] hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
            <div class="w-12 h-12 rounded-xl bg-[#00A896]/10 text-[#00A896] flex items-center justify-center mb-4 group-hover:bg-[#00A896] group-hover:text-white transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>
            </div>
            <h4 class="text-dark text-base font-bold mb-2">Land Monetisation Strategy</h4>
            <p class="text-muted-foreground text-sm leading-relaxed">Identifying the optimal monetisation route — outright sale, JV development, or revenue share — and executing with precision.</p>
          </div>
          <!-- JV Structuring -->
          <div class="re-service-card group p-6 rounded-2xl bg-white border border-border hover:border-[#00A896] hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
            <div class="w-12 h-12 rounded-xl bg-[#00A896]/10 text-[#00A896] flex items-center justify-center mb-4 group-hover:bg-[#00A896] group-hover:text-white transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m11 17 2 2a1 1 0 1 0 3-3"/><path d="m14 14 2.5 2.5a1 1 0 1 0 3-3l-3.88-3.88a3 3 0 0 0-4.24 0l-.88.88a1 1 0 1 1-3-3l2.81-2.81a5.79 5.79 0 0 1 7.06-.87l.47.28a2 2 0 0 0 1.42.25L21 4"/><path d="m21 3 1 11h-2"/><path d="M3 3 2 14l6.5 6.5a1 1 0 1 0 3-3"/><path d="M3 4h8"/></svg>
            </div>
            <h4 class="text-dark text-base font-bold mb-2">JV Partner Structuring</h4>
            <p class="text-muted-foreground text-sm leading-relaxed">Negotiating and structuring equitable joint development agreements aligning landowner and developer interests.</p>
          </div>
          <!-- Land Financing -->
          <div class="re-service-card group p-6 rounded-2xl bg-white border border-border hover:border-[#00A896] hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
            <div class="w-12 h-12 rounded-xl bg-[#00A896]/10 text-[#00A896] flex items-center justify-center mb-4 group-hover:bg-[#00A896] group-hover:text-white transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="5" rx="2"/><line x1="2" x2="22" y1="10" y2="10"/></svg>
            </div>
            <h4 class="text-dark text-base font-bold mb-2">Land Project Financing</h4>
            <p class="text-muted-foreground text-sm leading-relaxed">Construction and bridge finance solutions tailored to land-led development structures.</p>
          </div>
          <!-- Title & Due Diligence -->
          <div class="re-service-card group p-6 rounded-2xl bg-white border border-border hover:border-[#00A896] hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
            <div class="w-12 h-12 rounded-xl bg-[#00A896]/10 text-[#00A896] flex items-center justify-center mb-4 group-hover:bg-[#00A896] group-hover:text-white transition-colors">
