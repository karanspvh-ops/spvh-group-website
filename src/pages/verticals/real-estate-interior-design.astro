    <style>
      .re-tab {
        background: #ffffff;
        color: #1b202d;
        border: 2px solid #e1e7ef;
      }
      .re-tab:hover {
        border-color: #00A896;
        color: #00A896;
      }
      .re-tab.active {
        background: #00A896;
        color: #ffffff;
        border-color: #00A896;
        box-shadow: 0 8px 24px -8px rgba(0, 168, 150, 0.5);
      }
      .re-panel {
        animation: re-fade-in 0.4s ease-out;
      }
      @keyframes re-fade-in {
        from { opacity: 0; transform: translateY(8px); }
        to   { opacity: 1; transform: translateY(0); }
      }
    </style>

    <script>
      (function () {
        function initReTabs() {
          const tabs = document.querySelectorAll('[data-re-tab]');
          const panels = document.querySelectorAll('[data-re-panel]');
          tabs.forEach((tab) => {
            tab.addEventListener('click', () => {
              const target = tab.getAttribute('data-re-tab');
              tabs.forEach((t) => t.classList.remove('active'));
              tab.classList.add('active');
              panels.forEach((p) => {
                if (p.getAttribute('data-re-panel') === target) {
                  p.classList.remove('hidden');
                } else {
                  p.classList.add('hidden');
                }
              });
            });
          });
        }
        initReTabs();
        document.addEventListener('astro:page-load', initReTabs);
      })();
    </script>
