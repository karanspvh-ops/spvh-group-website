---
import BaseLayout from '@/layouts/BaseLayout.astro';
import VerticalNav from '@/components/VerticalNav.astro';
import { SITE } from '@/config/site';
---

<BaseLayout title={`Real Estate & Interior Design | ${SITE.name}`} description="SPVH Group's real estate and interior design vertical." >
  <section class="relative min-h-[90vh] flex items-center pt-20 overflow-hidden bg-dark">
    <div class="container mx-auto px-6 relative z-10 text-center">
      <a href="/#businesses" class="inline-block px-4 py-1 rounded-full bg-primary/20 backdrop-blur-md border border-primary/30 text-white text-sm font-bold uppercase tracking-widest mb-6 hover:bg-primary/40 transition-colors">Business Vertical</a>
      <h1 class="text-5xl md:text-7xl font-bold text-white mb-8 leading-[1.1]">
        <span class="text-primary uppercase">REAL ESTATE & INTERIOR DESIGN</span>
      </h1>
      <div class="bg-white/10 backdrop-blur-xl border border-white/20 p-8 rounded-2xl shadow-2xl max-w-2xl mx-auto">
        <p class="text-2xl font-bold text-primary mb-4">Coming Soon</p>
        <p class="text-xl text-dark-muted leading-relaxed">
          SPVH Group's real estate and interior design vertical is currently under development. Please check back soon for more information.
        </p>
      </div>
      <div class="mt-10">
        <a href="/#contact" class="px-10 py-4 bg-primary hover:bg-primary-hover text-white font-bold uppercase tracking-wider rounded-full transition-colors shadow-md">
          Contact Us
        </a>
      </div>
    </div>
  </section>

  <VerticalNav activePath="/verticals/real-estate-interior-design" />
</BaseLayout>
