          <section data-ps="src/pages/terms-of-service.astro:entire-agreement">
            <h2 class="text-dark text-2xl font-bold mb-4" data-ps="src/pages/terms-of-service.astro:ea-title">8. Entire Agreement and Contact Information</h2>
            <div class="space-y-6 text-foreground leading-relaxed" data-ps="src/pages/terms-of-service.astro:ea-content">
