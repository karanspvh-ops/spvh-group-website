---
import { SITE } from '@/config/site';
---

<header class="fixed top-4 z-50 bg-white/90 backdrop-blur-md border border-gray-100 shadow-lg shadow-black/5 rounded-full transition-all duration-500 py-2 md:py-5 flex items-center
  left-4 md:left-[2.5vw]
  w-auto md:w-[95vw]" id="main-header" data-ps="src/components/Navigation.astro:dt8k88">
  <div class="flex justify-between items-center w-full px-2 md:px-12 transition-all duration-500" id="nav-inner" data-ps="src/components/Navigation.astro:gqvsdd">
    <!-- Logo Left -->
    <div class="flex items-center shrink-0 gap-2" data-ps="src/components/Navigation.astro:gqvsdd">
      <a href="/" class="flex items-center md:-ml-4 transition-transform duration-300 active:scale-95" data-ps="src/components/Navigation.astro:7vkjsd">
        <!-- Round logo (mobile only) -->
        <img id="nav-logo-round" src="/images/SPVH-Round-LOGO-BLUE.webp" alt="SPVH" class="md:hidden h-16 w-16 object-contain shrink-0" data-ps="src/components/Navigation.astro:round-logo" />
        <!-- Full logo (desktop only) -->
        <img id="nav-logo-color" src="/images/SPVH-Logo-Updated-768.webp" alt="SPVH Group Logo" class="hidden md:block h-20 w-auto object-contain transition-all duration-500 origin-left" data-ps="src/components/Navigation.astro:d4d69u" />
      </a>
      <!-- Mobile Expand Arrow (always visible on mobile) -->
      <button id="mobile-expand-btn" class="md:hidden text-primary hover:text-primary-hover transition-all duration-300 flex items-center justify-center cursor-pointer bg-primary/10 hover:bg-primary/20 rounded-full h-10 w-10 shrink-0" aria-label="Open menu" data-ps="src/components/Navigation.astro:mobile-expand">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" id="mobile-expand-icon" class="transition-transform duration-300"><path d="m9 18 6-6-6-6"/></svg>
      </button>
      <!-- Desktop Expand Arrow (only used during smart-collapse on scroll) -->
      <button id="expand-nav-btn" class="hidden opacity-0 w-0 text-primary hover:text-primary-hover transition-all duration-300 items-center justify-center cursor-pointer bg-primary/10 hover:bg-primary/20 rounded-full h-10 shrink-0" aria-label="Expand navigation" data-ps="src/components/Navigation.astro:5ds8">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-chevron-right"><path d="m9 18 6-6-6-6"/></svg>
      </button>
    </div>

    <!-- Right Side Content (desktop only) -->
    <div id="nav-right-content" class="hidden md:flex items-center justify-end flex-1 ml-4 md:ml-8 transition-all duration-500 opacity-100 translate-x-0" data-ps="src/components/Navigation.astro:gqvsde">
      <!-- Right Aligned Desktop Nav -->
      <nav class="hidden md:flex flex-1 justify-end items-center gap-4 lg:gap-8 mr-6 lg:mr-10" data-ps="src/components/Navigation.astro:m59h3a">
      <a href="/about" class="nav-text-link relative group text-base lg:text-lg font-bold text-primary hover:text-primary-hover transition-colors uppercase tracking-wider whitespace-nowrap" data-ps="src/components/Navigation.astro:7vkjse">
        About
        <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-secondary transition-all duration-300 group-hover:w-full" data-ps="src/components/Navigation.astro:i2om6g"></span>
      </a>
      <div class="relative group" data-ps="src/components/Navigation.astro:dropdown-container">
        <a href="/#businesses" class="nav-text-link relative text-base lg:text-lg font-bold text-primary hover:text-primary-hover transition-colors uppercase tracking-wider flex items-center gap-1 whitespace-nowrap" data-ps="src/components/Navigation.astro:7vkjsf">
          Business Verticals
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-300 group-hover:rotate-180"><path d="m6 9 6 6 6-6"/></svg>
          <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-secondary transition-all duration-300 group-hover:w-full" data-ps="src/components/Navigation.astro:i2om6h"></span>
        </a>

        <!-- Dropdown Menu -->
        <div class="absolute top-full left-1/2 -translate-x-1/2 pt-[30px] opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 transform origin-top translate-y-2 group-hover:translate-y-0 z-50 min-w-[300px]" data-ps="src/components/Navigation.astro:gqvsdb">
          <div class="relative" data-ps="src/components/Navigation.astro:gqvsde">
            <!-- Caret / Tooltip Arrow -->
            <div class="absolute -top-2 left-1/2 -translate-x-1/2 w-4 h-4 bg-white/95 border-t border-l border-white/30 rotate-45 z-0" data-ps="src/components/Navigation.astro:caret"></div>

            <div class="relative bg-white/95 backdrop-blur-md rounded-2xl shadow-xl border border-white/30 py-2 overflow-hidden flex flex-col z-10" data-ps="src/components/Navigation.astro:gqvsdc">
              <a href="/financial-services" class="px-5 py-3 text-sm font-semibold text-gray-700 hover:text-primary hover:bg-gray-50 transition-colors uppercase tracking-wider border-b border-gray-100 last:border-0" data-ps="src/components/Navigation.astro:7vkjsb">Financial Services</a>
              <a href="/media-entertainment" class="px-5 py-3 text-sm font-semibold text-gray-700 hover:text-primary hover:bg-gray-50 transition-colors uppercase tracking-wider border-b border-gray-100 last:border-0" data-ps="src/components/Navigation.astro:7vkjsd">Media & Entertainment</a>
              <a href="/hospitality" class="px-5 py-3 text-sm font-semibold text-gray-700 hover:text-primary hover:bg-gray-50 transition-colors uppercase tracking-wider border-b border-gray-100 last:border-0" data-ps="src/components/Navigation.astro:7vkjsc">Hospitality</a>
              <a href="/verticals/automotive" class="px-5 py-3 text-sm font-semibold text-gray-700 hover:text-primary hover:bg-gray-50 transition-colors uppercase tracking-wider border-b border-gray-100 last:border-0" data-ps="src/components/Navigation.astro:7vkjsa">Automotive</a>
              <a href="/verticals/technology-research" class="px-5 py-3 text-sm font-semibold text-gray-700 hover:text-primary hover:bg-gray-50 transition-colors uppercase tracking-wider border-b border-gray-100 last:border-0" data-ps="src/components/Navigation.astro:7vkjsf">Technology & Research</a>
              <a href="/verticals/real-estate-interior-design" class="px-5 py-3 text-sm font-semibold text-gray-700 hover:text-primary hover:bg-gray-50 transition-colors uppercase tracking-wider border-b border-gray-100 last:border-0" data-ps="src/components/Navigation.astro:7vkjse">Real Estate & Interior Design</a>
            </div>
          </div>
        </div>
      </div>
      <a href="/our-programs" class="nav-text-link relative group text-base lg:text-lg font-bold text-primary hover:text-primary-hover transition-colors uppercase tracking-wider whitespace-nowrap" data-ps="src/components/Navigation.astro:our-programs-nav">
        Our Programs
        <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-secondary transition-all duration-300 group-hover:w-full" data-ps="src/components/Navigation.astro:i2om6i"></span>
      </a>
      </nav>

      <!-- Right Action Items (desktop) -->
      <div class="flex items-center gap-3 shrink-0" data-ps="src/components/Navigation.astro:right-actions">
        <!-- Contact Button -->
        <a href="/#contact" class="flex items-center justify-center bg-primary text-white font-bold uppercase tracking-wider rounded-full hover:bg-primary-hover transition-colors shadow-md hover:shadow-lg whitespace-nowrap w-12 h-12 lg:w-auto lg:h-auto lg:px-8 lg:py-3" data-ps="src/components/Navigation.astro:kd8n5z">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="block lg:hidden"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          <span class="hidden lg:block text-sm xl:text-lg" data-ps="src/components/Navigation.astro:i2om6i">Contact</span>
        </a>
      </div>
    </div>
  </div>
</header>

<!-- Mobile Menu Overlay (sibling of header so backdrop-blur doesn't constrain it) -->
<div id="mobile-menu-backdrop" class="fixed inset-0 bg-dark/40 backdrop-blur-sm z-[55] hidden" data-ps="src/components/Navigation.astro:mobile-backdrop"></div>
<div id="mobile-menu" class="fixed top-24 left-4 right-4 bg-white border border-gray-200 shadow-2xl rounded-3xl z-[60] hidden flex-col py-6 px-5 items-stretch overflow-y-auto max-h-[80vh]" data-ps="src/components/Navigation.astro:gqvsde">
    <button id="close-menu-btn" class="self-end mb-2 text-gray-600 hover:text-primary p-2 focus:outline-none bg-gray-100 hover:bg-gray-200 rounded-full transition-colors" aria-label="Close menu" data-ps="src/components/Navigation.astro:4mvac">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
    </button>
    <nav class="flex flex-col items-stretch gap-1 w-full" data-ps="src/components/Navigation.astro:m59h39">
      <a href="/about" class="block px-4 py-3 text-[15px] font-bold text-primary hover:bg-primary/5 rounded-xl uppercase tracking-wider mobile-link transition-colors" data-ps="src/components/Navigation.astro:kd8n5y">About</a>

      <div class="w-full" data-ps="src/components/Navigation.astro:gqvsdd">
        <button id="mobile-verticals-trigger" class="flex items-center justify-between w-full px-4 py-3 text-[15px] font-bold text-primary hover:bg-primary/5 rounded-xl uppercase tracking-wider transition-colors" data-ps="src/components/Navigation.astro:kd8n5x">
          <span>Business Verticals</span>
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-300 shrink-0" id="mobile-verticals-icon"><path d="m6 9 6 6 6-6"/></svg>
        </button>
        <div id="mobile-verticals-menu" class="hidden flex-col gap-1 w-full pl-4 mt-1 mb-1 border-l-2 border-secondary/30" data-ps="src/components/Navigation.astro:gqvsde">
          <a href="/financial-services" class="block px-4 py-2.5 text-[13px] font-semibold text-secondary hover:bg-secondary/5 rounded-lg mobile-link uppercase tracking-wide" data-ps="src/components/Navigation.astro:kd8n5y">Financial Services</a>
          <a href="/media-entertainment" class="block px-4 py-2.5 text-[13px] font-semibold text-secondary hover:bg-secondary/5 rounded-lg mobile-link uppercase tracking-wide" data-ps="src/components/Navigation.astro:kd8n5w">Media &amp; Entertainment</a>
          <a href="/hospitality" class="block px-4 py-2.5 text-[13px] font-semibold text-secondary hover:bg-secondary/5 rounded-lg mobile-link uppercase tracking-wide" data-ps="src/components/Navigation.astro:kd8n5x">Hospitality</a>
          <a href="/verticals/automotive" class="block px-4 py-2.5 text-[13px] font-semibold text-secondary hover:bg-secondary/5 rounded-lg mobile-link uppercase tracking-wide" data-ps="src/components/Navigation.astro:kd8n5z">Automotive</a>
          <a href="/verticals/technology-research" class="block px-4 py-2.5 text-[13px] font-semibold text-secondary hover:bg-secondary/5 rounded-lg mobile-link uppercase tracking-wide" data-ps="src/components/Navigation.astro:kd8n5u">Technology &amp; Research</a>
          <a href="/verticals/real-estate-interior-design" class="block px-4 py-2.5 text-[13px] font-semibold text-secondary hover:bg-secondary/5 rounded-lg mobile-link uppercase tracking-wide" data-ps="src/components/Navigation.astro:kd8n5v">Real Estate &amp; Interior Design</a>
        </div>
      </div>

      <a href="/our-programs" class="block px-4 py-3 text-[15px] font-bold text-primary hover:bg-primary/5 rounded-xl uppercase tracking-wider mobile-link transition-colors" data-ps="src/components/Navigation.astro:our-programs-mobile">Our Programs</a>

      <a href="/#contact" class="block text-center mt-3 px-6 py-3 bg-primary text-white text-[15px] font-bold uppercase tracking-wider rounded-full hover:bg-primary-hover transition-colors shadow-md mobile-link" data-ps="src/components/Navigation.astro:kd8n5w">Contact</a>
    </nav>
</div>

<script>
  // Smart Collapse Navigation Logic (DESKTOP ONLY)
  const header = document.getElementById('main-header');
  const logoColor = document.getElementById('nav-logo-color');
  const expandBtn = document.getElementById('expand-nav-btn');
  const rightContent = document.getElementById('nav-right-content');
  const innerContainer = document.getElementById('nav-inner');

  const isDesktop = () => window.innerWidth >= 768;

  let lastScrollY = window.scrollY;
  let isManuallyExpanded = false;

  function setNavState(state) {
    if (!header || !isDesktop()) return;
    if (state === 'expanded') {
      header.classList.remove('md:w-[320px]');
      header.classList.add('md:w-[95vw]');

      rightContent.classList.remove('opacity-0', 'invisible', 'translate-x-4', 'absolute');
      rightContent.classList.add('opacity-100', 'translate-x-0');

      expandBtn.classList.remove('flex', 'opacity-100', 'w-10', 'ml-4', 'md:ml-6');
      expandBtn.classList.add('hidden', 'opacity-0', 'w-0');
    } else if (state === 'collapsed') {
      header.classList.remove('md:w-[95vw]');
      header.classList.add('md:w-[320px]');

      rightContent.classList.remove('opacity-100', 'translate-x-0');
      rightContent.classList.add('opacity-0', 'invisible', 'translate-x-4', 'absolute');

      expandBtn.classList.remove('hidden', 'opacity-0', 'w-0');
      expandBtn.classList.add('flex', 'opacity-100', 'w-10', 'ml-4', 'md:ml-6');
    }
  }

  // Initial load behavior
  function initNav() {
    if (!isDesktop()) return; // mobile is always compact
    const isHome = window.location.pathname === '/' || window.location.pathname === '/index.html';
    if (isHome && window.scrollY <= 10) {
      setNavState('expanded');
    } else {
      setNavState('collapsed');
    }
  }

  // Run on load
  initNav();
  document.addEventListener('astro:page-load', initNav);

  // Scroll behavior (desktop only)
  window.addEventListener('scroll', () => {
    if (!isDesktop()) return;
    const currentScrollY = window.scrollY;

    if (currentScrollY > lastScrollY && currentScrollY > 20) {
      setNavState('collapsed');
      isManuallyExpanded = false;
    } else if (currentScrollY < lastScrollY) {
      setNavState('expanded');
    }

    lastScrollY = currentScrollY;
  }, { passive: true });

  // Manual override click (desktop)
  expandBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    isManuallyExpanded = true;
    setNavState('expanded');
  });

  // ============= MOBILE MENU LOGIC =============
  const mobileExpandBtn = document.getElementById('mobile-expand-btn');
  const mobileExpandIcon = document.getElementById('mobile-expand-icon');
  const closeMenuBtn = document.getElementById('close-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const mobileMenuBackdrop = document.getElementById('mobile-menu-backdrop');
  const mobileLinks = document.querySelectorAll('.mobile-link');

  let isMenuOpen = false;

  function openMenu() {
    isMenuOpen = true;
    mobileMenu?.classList.remove('hidden');
    mobileMenu?.classList.add('flex');
    mobileMenuBackdrop?.classList.remove('hidden');
    mobileExpandIcon?.classList.add('rotate-90');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    isMenuOpen = false;
    mobileMenu?.classList.add('hidden');
    mobileMenu?.classList.remove('flex');
    mobileMenuBackdrop?.classList.add('hidden');
    mobileExpandIcon?.classList.remove('rotate-90');
    document.body.style.overflow = '';
  }

  function toggleMenu() {
    if (isMenuOpen) closeMenu();
    else openMenu();
  }

  // Mobile expand arrow opens full menu
  mobileExpandBtn?.addEventListener('click', toggleMenu);
  closeMenuBtn?.addEventListener('click', closeMenu);
  mobileMenuBackdrop?.addEventListener('click', closeMenu);

  mobileLinks.forEach(link => {
    link.addEventListener('click', closeMenu);
  });

  // Mobile Dropdown Toggle
  const verticalsTrigger = document.getElementById('mobile-verticals-trigger');
  const verticalsMenu = document.getElementById('mobile-verticals-menu');
  const verticalsIcon = document.getElementById('mobile-verticals-icon');

  verticalsTrigger?.addEventListener('click', () => {
    const isHidden = verticalsMenu?.classList.contains('hidden');
    if (isHidden) {
      verticalsMenu?.classList.remove('hidden');
      verticalsMenu?.classList.add('flex');
      verticalsIcon?.classList.add('rotate-180');
    } else {
      verticalsMenu?.classList.add('hidden');
      verticalsMenu?.classList.remove('flex');
      verticalsIcon?.classList.remove('rotate-180');
    }
  });

  // Handle smooth scrolling for hash links when on the same page
  document.querySelectorAll('a[href^="/#"]').forEach(anchor => {
    anchor.addEventListener('click', function (e) {
      const href = this.getAttribute('href');
      const targetId = href.split('#')[1];
      const targetElement = document.getElementById(targetId);

      if (window.location.pathname === '/' && targetElement) {
        e.preventDefault();

        const headerOffset = 100;
        const elementPosition = targetElement.getBoundingClientRect().top;
        const offsetPosition = elementPosition + window.pageYOffset - headerOffset;

        window.scrollTo({
          top: offsetPosition,
          behavior: 'smooth'
        });

        history.pushState(null, null, '#' + targetId);
      }
    });
  });

  // Handle scrolling when arriving from another page with a hash
  window.addEventListener('load', () => {
    if (window.location.hash && window.location.pathname === '/') {
      const targetElement = document.querySelector(window.location.hash);
      if (targetElement) {
        setTimeout(() => {
          const headerOffset = 100;
          const elementPosition = targetElement.getBoundingClientRect().top;
          const offsetPosition = elementPosition + window.pageYOffset - headerOffset;

          window.scrollTo({
            top: offsetPosition,
            behavior: 'smooth'
          });
        }, 150);
      }
    }
  });
</script>
