---
import 'altcha';
---

<div id="contact-modal" class="fixed inset-0 z-[100] hidden overflow-y-auto" aria-labelledby="modal-title" role="dialog" aria-modal="true" data-ps="src/components/ContactModal.astro:modal-root">
  <!-- Backdrop -->
  <div id="contact-modal-backdrop" class="fixed inset-0 bg-dark/80 backdrop-blur-sm transition-opacity" data-ps="src/components/ContactModal.astro:backdrop"></div>

  <div class="flex min-h-full items-center justify-center p-4 text-center sm:p-0" data-ps="src/components/ContactModal.astro:container">
    <div class="relative transform overflow-hidden rounded-2xl bg-[#222836] text-left shadow-2xl transition-all sm:my-8 sm:w-full sm:max-w-2xl border border-white/10" data-ps="src/components/ContactModal.astro:panel">
      <!-- Close Button -->
      <button 
        type="button" 
        id="contact-modal-close"
        class="absolute right-6 top-6 text-dark-muted hover:text-white transition-colors z-10"
        aria-label="Close modal"
       data-ps="src/components/ContactModal.astro:close-btn">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
      </button>

      <div class="p-8 lg:p-12" data-ps="src/components/ContactModal.astro:content">
        <div class="mb-8" data-ps="src/components/ContactModal.astro:header">
          <span class="text-[12px] font-bold uppercase tracking-[2px] text-secondary mb-2 block" data-ps="src/components/ContactModal.astro:kicker">GET IN TOUCH</span>
          <h2 class="text-3xl font-bold text-white" id="modal-title" data-ps="src/components/ContactModal.astro:title">Speak to an Expert.</h2>
          <p class="text-dark-muted mt-2" data-ps="src/components/ContactModal.astro:description">Fill out the form below and we'll get back to you within 24 hours.</p>
        </div>

        <div id="modal-contact-status" class="hidden mb-6 px-4 py-3 rounded-lg text-sm" data-ps="src/components/ContactModal.astro:status"></div>
        
        <form id="modal-contact-form" class="space-y-6">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6" data-ps="src/components/ContactModal.astro:grid-1">
            <div class="space-y-2" data-ps="src/components/ContactModal.astro:name-field">
              <label class="text-[12px] font-bold text-dark-muted uppercase" data-ps="src/components/ContactModal.astro:label-name">Name</label>
              <input 
                type="text" 
                name="name"
                required
                placeholder="John Doe"
                class="w-full bg-transparent border border-white/10 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-primary transition-colors"
              />
            </div>
            <div class="space-y-2" data-ps="src/components/ContactModal.astro:email-field">
              <label class="text-[12px] font-bold text-dark-muted uppercase" data-ps="src/components/ContactModal.astro:label-email">Email</label>
              <input 
                type="email" 
                name="email"
                required
                placeholder="john@example.com"
                class="w-full bg-transparent border border-white/10 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-primary transition-colors"
              />
            </div>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6" data-ps="src/components/ContactModal.astro:grid-2">
            <div class="space-y-2" data-ps="src/components/ContactModal.astro:company-field">
              <label class="text-[12px] font-bold text-dark-muted uppercase" data-ps="src/components/ContactModal.astro:label-company">Company Name</label>
              <input 
                type="text" 
                name="company"
                placeholder="Company Ltd."
                class="w-full bg-transparent border border-white/10 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-primary transition-colors"
              />
            </div>
            <div class="space-y-2" data-ps="src/components/ContactModal.astro:website-field">
              <label class="text-[12px] font-bold text-dark-muted uppercase" data-ps="src/components/ContactModal.astro:label-website">Website (Optional)</label>
              <input 
                type="text" 
                name="website"
                placeholder="www.xyz.com"
                class="w-full bg-transparent border border-white/10 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-primary transition-colors"
              />
            </div>
          </div>

          <div class="space-y-2" data-ps="src/components/ContactModal.astro:vertical-field">
            <label class="text-[12px] font-bold text-dark-muted uppercase" data-ps="src/components/ContactModal.astro:label-vertical">Select Vertical</label>
            <select 
              name="vertical"
              required
              class="w-full bg-[#222836] border border-white/10 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-primary transition-colors appearance-none"
            >
              <option value="" disabled selected>Select a business vertical</option>
              <option value="Financial Services">Financial Services</option>
              <option value="Automotive">Automotive</option>
              <option value="Hospitality">Hospitality</option>
              <option value="Real Estate & Interior Design">Real Estate & Interior Design</option>
              <option value="Technology & Research">Technology & Research</option>
              <option value="Media & Entertainment">Media & Entertainment</option>
            </select>
          </div>

          <div class="space-y-2" data-ps="src/components/ContactModal.astro:subject-field">
            <label class="text-[12px] font-bold text-dark-muted uppercase" data-ps="src/components/ContactModal.astro:label-subject">Subject</label>
            <input 
              type="text" 
              name="subject"
              required
              placeholder="Inquiry about..."
              class="w-full bg-transparent border border-white/10 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-primary transition-colors"
            />
          </div>

          <div class="space-y-2" data-ps="src/components/ContactModal.astro:message-field">
            <label class="text-[12px] font-bold text-dark-muted uppercase" data-ps="src/components/ContactModal.astro:label-message">Message</label>
            <textarea 
              name="message"
              required
              rows="3" 
              placeholder="Your message here..."
              class="w-full bg-transparent border border-white/10 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-primary transition-colors resize-none"
            ></textarea>
          </div>

          <div class="flex justify-center" data-ps="src/components/ContactModal.astro:altcha-container">
            <altcha-widget challenge="/psapi-internal-v1/altcha/challenge" display="invisible" auto="onfocus"></altcha-widget>
          </div>

          <button 
            type="submit"
            id="modal-contact-submit"
            class="w-full bg-secondary text-white font-bold uppercase tracking-wider py-4 rounded-xl hover:bg-secondary-hover transition-colors shadow-lg"
           data-ps="src/components/ContactModal.astro:submit-btn">
            SEND MESSAGE
          </button>
        </form>
      </div>
    </div>
  </div>
</div>

<script>
  const modal = document.getElementById('contact-modal');
  const backdrop = document.getElementById('contact-modal-backdrop');
  const closeBtn = document.getElementById('contact-modal-close');
  const form = document.getElementById('modal-contact-form') as HTMLFormElement;
  const status = document.getElementById('modal-contact-status') as HTMLDivElement;
  const submitBtn = document.getElementById('modal-contact-submit') as HTMLButtonElement;

  const openModal = () => {
    modal?.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  };

  const closeModal = () => {
    modal?.classList.add('hidden');
    document.body.style.overflow = '';
  };

  closeBtn?.addEventListener('click', closeModal);
  backdrop?.addEventListener('click', closeModal);

  // Global trigger
  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    const trigger = target.closest('[data-modal-trigger="contact"]');
    if (trigger) {
      e.preventDefault();
      openModal();
    }
  });

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    submitBtn.disabled = true;
    submitBtn.textContent = 'SENDING...';

    const formData = new FormData(form);
    const data = Object.fromEntries(formData);
    
    // Add auto-acknowledgment fields
    data._confirmationSubject = "We received your inquiry - SPVH Group";
    data._confirmationBody = "Thank you for reaching out to SPVH Group. We have received your message and our team will get back to you shortly.\n\nBest regards,\nSPVH Group Team";

    try {
      const response = await fetch('/psapi-internal-v1/forms/submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      const result = await response.json();

      if (result.success) {
        status.className = 'mb-6 px-4 py-3 rounded-lg bg-secondary/20 border border-secondary text-secondary text-sm';
        status.textContent = 'Thank you! Your message has been sent.';
        form.reset();
        
        // Auto close modal after success
        setTimeout(() => {
          closeModal();
          status.classList.add('hidden');
        }, 3000);
      } else {
        throw new Error(result.error || 'Failed to send');
      }
    } catch (err) {
      status.className = 'mb-6 px-4 py-3 rounded-lg bg-red-500/20 border border-red-500 text-red-500 text-sm';
      status.textContent = err instanceof Error ? err.message : 'Failed to send. Please try again.';
      status.classList.remove('hidden');
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = 'SEND MESSAGE';
    }
  });
</script>