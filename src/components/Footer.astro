---
import { SITE } from '@/config/site';

const currentYear = new Date().getFullYear();
---

<footer class="bg-[#0A1931] text-[#94A3B8] py-16 px-6 lg:px-12 border-t border-white/5" data-ps="src/components/Footer.astro:ikmf30">
  <div class="max-w-[1280px] mx-auto" data-ps="src/components/Footer.astro:p4vf85">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-[2fr_1fr_1fr_1fr] gap-12" data-ps="src/components/Footer.astro:p4vf86">
      <!-- Column 1: Brand & Connect -->
      <div data-ps="src/components/Footer.astro:brand-col">
        <a href="/" class="inline-block mb-8" data-ps="src/components/Footer.astro:7gqc0e">
          <img 
            src="/images/SPVH-LOGO-WHITE_2-768-768-768.webp" 
            alt="SPVH Group" 
            class="h-[80px] w-auto" data-ps="src/components/Footer.astro:4qdjf5" />
        </a>
        <p class="text-[14px] leading-relaxed text-[#94A3B8] mb-8" data-ps="src/components/Footer.astro:csfaq">
          SPVH Private Limited — A specialized holding group focused on wealth management and alternative investment strategies.
        </p>

        <!-- Connect Section -->
        <div class="mt-8" data-ps="src/components/Footer.astro:connect-section-relocated">
          <h2 class="text-[12px] font-bold uppercase tracking-widest text-white mb-6" data-ps="src/components/Footer.astro:f0091a">Connect</h2>
          <a href="mailto:info@spvhgroup.com" class="block text-[14px] text-[#94A3B8] no-underline hover:text-[#00A896] transition-colors mb-4" target="_blank" data-ps="src/components/Footer.astro:8o2pi">info@spvhgroup.com</a>
          <div class="flex gap-4 items-center mt-3" data-ps="src/components/Footer.astro:p4vf8b">
            <a href="https://www.linkedin.com/company/spvhgroup" target="_blank" class="text-[#00A896] hover:text-[#00A896]/80 transition-colors" data-ps="src/components/Footer.astro:8o2pj">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-linkedin"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
            </a>
            <a href="https://twitter.com/spvhgroup" target="_blank" class="text-[#00A896] hover:text-[#00A896]/80 transition-colors" data-ps="src/components/Footer.astro:8o2pk">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-twitter"><path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"/></svg>
            </a>
            <a href="https://www.instagram.com/spvhgroup" target="_blank" class="text-[#00A896] hover:text-[#00A896]/80 transition-colors" data-ps="src/components/Footer.astro:8o2pl">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-instagram"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
            </a>
          </div>
        </div>
      </div>

      <!-- Column 2: Platform -->
      <div data-ps="src/components/Footer.astro:platform-col">
        <h2 class="text-[12px] font-bold uppercase tracking-widest text-white mb-6" data-ps="src/components/Footer.astro:w7klou">Platform</h2>
        <ul class="space-y-3 p-0 m-0 list-none">
          <li data-ps="src/components/Footer.astro:wyji6k"><a href="/" class="text-[14px] text-[#94A3B8] no-underline hover:text-[#00A896] transition-colors" data-ps="src/components/Footer.astro:7gqc0f">Home</a></li>
          <li data-ps="src/components/Footer.astro:wyji6l"><a href="/about" class="text-[14px] text-[#94A3B8] no-underline hover:text-[#00A896] transition-colors" data-ps="src/components/Footer.astro:7gqc0g">About Us</a></li>
          <li data-ps="src/components/Footer.astro:first-cheque"><a href="/our-programs" class="text-[14px] text-[#94A3B8] no-underline hover:text-[#00A896] transition-colors" data-ps="src/components/Footer.astro:8o2pk">Our Programs</a></li>
          <li data-ps="src/components/Footer.astro:csr-link"><a href="/csr-philanthropy" class="text-[14px] text-[#94A3B8] no-underline hover:text-[#00A896] transition-colors" data-ps="src/components/Footer.astro:8o2pn">CSR & Philanthropy</a></li>
        </ul>
      </div>

      <!-- Column 3: Our Businesses -->
      <div data-ps="src/components/Footer.astro:businesses-col">
        <h2 class="text-[12px] font-bold uppercase tracking-widest text-white mb-6" data-ps="src/components/Footer.astro:bus-heading">Our Businesses</h2>
        <ul class="space-y-3 p-0 m-0 list-none">
          <li data-ps="src/components/Footer.astro:bus-fin"><a href="/financial-services" class="text-[14px] text-[#94A3B8] no-underline hover:text-[#00A896] transition-colors" data-ps="src/components/Footer.astro:bus-fin-link">Financial Services</a></li>
          <li data-ps="src/components/Footer.astro:bus-med"><a href="/media-entertainment" class="text-[14px] text-[#94A3B8] no-underline hover:text-[#00A896] transition-colors" data-ps="src/components/Footer.astro:bus-med-link">Media & Entertainment</a></li>
          <li data-ps="src/components/Footer.astro:bus-hos"><a href="/hospitality" class="text-[14px] text-[#94A3B8] no-underline hover:text-[#00A896] transition-colors" data-ps="src/components/Footer.astro:bus-hos-link">Hospitality</a></li>
          <li data-ps="src/components/Footer.astro:bus-aut"><a href="/verticals/automotive" class="text-[14px] text-[#94A3B8] no-underline hover:text-[#00A896] transition-colors" data-ps="src/components/Footer.astro:bus-aut-link">Automotive</a></li>
          <li data-ps="src/components/Footer.astro:bus-tec"><a href="/verticals/technology-research" class="text-[14px] text-[#94A3B8] no-underline hover:text-[#00A896] transition-colors" data-ps="src/components/Footer.astro:bus-tec-link">Technology & Research</a></li>
          <li data-ps="src/components/Footer.astro:bus-rea"><a href="/verticals/real-estate-interior-design" class="text-[14px] text-[#94A3B8] no-underline hover:text-[#00A896] transition-colors" data-ps="src/components/Footer.astro:bus-rea-link">Real Estate & Interior Design</a></li>
        </ul>
      </div>

      <!-- Column 4: Compliance -->
      <div data-ps="src/components/Footer.astro:compliance-col">
        <h2 class="text-[12px] font-bold uppercase tracking-widest text-white mb-6" data-ps="src/components/Footer.astro:compliance-heading">Compliance</h2>
        <ul class="space-y-3 p-0 m-0 list-none">
          <li data-ps="src/components/Footer.astro:privacy-link"><a href="/privacy-policy" class="text-[14px] text-[#94A3B8] no-underline hover:text-[#00A896] transition-colors" data-ps="src/components/Footer.astro:8o2pl">Privacy Policy</a></li>
          <li data-ps="src/components/Footer.astro:terms-link"><a href="/terms-of-service" class="text-[14px] text-[#94A3B8] no-underline hover:text-[#00A896] transition-colors" data-ps="src/components/Footer.astro:8o2pm">Terms of Service</a></li>
          <li data-ps="src/components/Footer.astro:regulatory-link"><a href="/regulatory-disclosures" class="text-[14px] text-[#94A3B8] no-underline hover:text-[#00A896] transition-colors" data-ps="src/components/Footer.astro:8o2pn">Regulatory Disclosures</a></li>
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="border-t border-white/10 mt-16 pt-8 flex flex-col md:flex-row justify-between items-center gap-4" data-ps="src/components/Footer.astro:p4vf8a">
      <p class="text-[12px] text-[#94A3B8]" data-ps="src/components/Footer.astro:csfar">
        © {currentYear} SPVH Private Limited. All rights reserved.
      </p>
      <button 
        onclick="window.scrollTo({ top: 0, behavior: 'smooth' })"
        class="w-10 h-10 rounded-full border border-white/10 flex items-center justify-center text-[#94A3B8] hover:text-white hover:border-[#00A896] hover:bg-[#00A896]/10 transition-all cursor-pointer" 
        aria-label="Back to Top"
        data-ps="src/components/Footer.astro:back-to-top"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-chevron-up"><path d="m18 15-6-6-6 6"/></svg>
      </button>
    </div>
  </div>
</footer>
