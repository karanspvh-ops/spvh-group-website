  },
  {
    id: "saurav-prakash",
    name: "Saurav Prakash",
    role: "Managing Partner\nInvestment Banking",
    image: "/images/Saurav-320.webp",
    email: "saurav.prakash@bpaconsulting.in",
    linkedin: "https://www.linkedin.com/in/sauravprakash23/",
