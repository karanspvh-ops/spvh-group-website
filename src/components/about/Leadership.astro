    bio: "Directing real estate ventures and interior design projects to build robust growth frameworks.",
    imageNotAvailable: true
  },
  {
    id: "vikram-malhotra",
    name: "Vikram Malhotra",
    role: "Partner\nTechnology & Artificial Intelligence",
    image: "https://images.pexels.com/photos/10657877/pexels-photo-10657877.jpeg?auto=compress&cs=tinysrgb&w=800",
    bio: "Strategic advisor for global market entry and cross-border investment frameworks.",
    quote: "Global strategy is not about being everywhere; it is about being exactly where value is created."
  },
  {
    id: "ananya-desai",
    name: "Ananya Desai",
    role: "Head\nLegal & Corporate Governance",
    image: "https://images.pexels.com/photos/13331367/pexels-photo-13331367.jpeg?auto=compress&cs=tinysrgb&w=800",
    bio: "Ensuring institutional-grade compliance and governance across all group subsidiaries.",
    quote: "Governance is the silent architect of institutional longevity."
  },
  {
    id: "rahul-kapur",
    name: "Rahul Kapur",
    role: "Head\nCompliance and regulatory",
