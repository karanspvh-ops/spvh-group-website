---

<section class="py-32 px-6 lg:px-12 bg-surface relative" data-ps="src/components/about/Leadership.astro:8c142p">
  <div class="max-w-[1280px] mx-auto" data-ps="src/components/about/Leadership.astro:7c332k">
    
    <div class="text-center mb-20 hero-animate" data-ps="src/components/about/Leadership.astro:p8v49">
      <h2 class="text-4xl md:text-5xl font-bold text-dark tracking-tight mb-6" data-ps="src/components/about/Leadership.astro:phzaaf">Leadership at SPVH Group</h2>
      <p class="text-lg text-muted-foreground max-w-2xl mx-auto" data-ps="src/components/about/Leadership.astro:2cf0q3">The strategic minds and industry experts guiding our investments across diverse verticals.</p>
    </div>

    <!-- Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8" data-ps="src/components/about/Leadership.astro:x9v92">
      {team.map((member, __psIdx) => (
        <button
          class="group text-left bg-white rounded-3xl overflow-hidden shadow-sm hover:shadow-xl hover:-translate-y-2 transition-all duration-300 border border-border/50 reveal focus:outline-none focus:ring-4 focus:ring-primary/20"
          onclick={`document.getElementById('modal-${member.id}').showModal()`}
          aria-label={`View profile for ${member.name}`}
         data-ps="src/components/about/Leadership.astro:k4m38">
          
          <div class="aspect-square w-full overflow-hidden bg-surface relative" data-ps="src/components/about/Leadership.astro:m9k12">
            {member.image ? (
              <div class="w-full h-full relative" data-ps={`src/components/about/Leadership.astro:kcs771-${__psIdx}`}>
                <img 
                  src={member.image} 
                  alt={member.name}
                  class:list={[
                    "w-full h-full object-cover transition-transform duration-700 ease-out",
                    member.id === 'karan-nagda' ? "object-[50%_0%] group-hover:scale-110" : (member.id === 'atiq-kapadia' ? "object-[50%_20%] group-hover:scale-110" : "group-hover:scale-110"),
                    (member.imageComingSoon || member.imageNotAvailable) && "blur-md opacity-50 grayscale-[50%]"
                  ]}
                  loading="lazy"
                data-ps="src/components/about/Leadership.astro:n2b38"/>
                {(member.imageComingSoon || member.imageNotAvailable) && (
                  <div class="absolute inset-0 flex items-center justify-center bg-white/40 backdrop-blur-md z-0" data-ps={`src/components/about/Leadership.astro:kcs772-${__psIdx}`}>
                    <span class="text-white font-bold tracking-widest text-xs sm:text-sm uppercase px-5 py-2 bg-dark/70 rounded-full text-center shadow-lg" data-ps={`src/components/about/Leadership.astro:56do2b-${__psIdx}`}>Image not available</span>
                  </div>
                )}
              </div>
            ) : (
              <div class="w-full h-full flex items-center justify-center bg-gray-100 text-muted-foreground font-medium text-sm transition-transform duration-700 ease-out group-hover:scale-110" data-ps={`src/components/about/Leadership.astro:kcs772-${__psIdx}`}>
                {member.imageNotAvailable ? "Image not available" : "Image coming soon"}
              </div>
            )}
            <div class="absolute inset-0 bg-gradient-to-t from-dark/90 via-dark/20 to-transparent opacity-80 pointer-events-none" data-ps="src/components/about/Leadership.astro:c9v27"></div>
            
            <!-- Hover Logo -->
            <div class="absolute top-6 right-6 z-10 opacity-0 group-hover:opacity-100 transition-all duration-500 transform -translate-y-2 group-hover:translate-y-0" data-ps="src/components/about/Leadership.astro:logo-hover">
              <img 
                src="/images/SPVH-Round-LOGO-320.webp" 
                alt="SPVH Logo" 
                class="h-10 w-auto" data-ps={`src/components/about/Leadership.astro:9igrg5-${__psIdx}`} />
            </div>

            <div class="absolute bottom-0 left-0 p-8 w-full transition-transform duration-500" data-ps="src/components/about/Leadership.astro:q2p19">
              <h3 class="text-2xl font-bold text-white mb-2" data-ps={`src/components/about/Leadership.astro:p0xn5h-${__psIdx}`}>{member.name}</h3>
              <p class="text-sm font-semibold uppercase tracking-wider text-white/80 whitespace-pre-line" data-ps={`src/components/about/Leadership.astro:2cf0q4-${__psIdx}`}>{member.role}</p>
            </div>
            
            <!-- Click Indicator -->
            <div class="absolute bottom-8 right-8 w-10 h-10 rounded-full bg-white/20 backdrop-blur-sm flex items-center justify-center text-white opacity-0 group-hover:opacity-100 transition-opacity" data-ps="src/components/about/Leadership.astro:w3m92">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
            </div>
          </div>
          
        </button>
      ))}
    </div>
  </div>

  <!-- Modals -->
  {team.map((member, __psIdx) => {
    const prev = __psIdx > 0 ? team[__psIdx - 1] : null;
    const next = __psIdx < team.length - 1 ? team[__psIdx + 1] : null;
    return (
    <dialog
      id={`modal-${member.id}`}
      class="w-full max-w-none h-full max-h-none m-0 p-0 bg-transparent border-0 backdrop:bg-dark/60 backdrop:backdrop-blur-sm shadow-none"
    data-ps="src/components/about/Leadership.astro:h8k31">
      
      <div class="w-full h-full flex items-center justify-center p-4" data-ps={`src/components/about/Leadership.astro:kcs773-${__psIdx}`}>
        
        {/* Navigation - Left */}
        {prev && (
          <button 
            onclick={`document.getElementById('modal-${member.id}').close(); document.getElementById('modal-${prev.id}').showModal()`}
            class="fixed left-2 lg:left-8 top-1/2 -translate-y-1/2 flex items-center gap-1 md:gap-2 text-white hover:text-white/90 transition-colors font-bold tracking-wide text-lg z-50 focus:outline-none"
            aria-label={`Previous: ${prev.name}`} data-ps={`src/components/about/Leadership.astro:13zpv1-${__psIdx}`}>
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
            <span class="hidden md:inline" data-ps={`src/components/about/Leadership.astro:56do2d-${__psIdx}`}>{prev.name}</span>
          </button>
        )}

        {/* Navigation - Right */}
        {next && (
          <button 
            onclick={`document.getElementById('modal-${member.id}').close(); document.getElementById('modal-${next.id}').showModal()`}
            class="fixed right-2 lg:right-8 top-1/2 -translate-y-1/2 flex items-center gap-1 md:gap-2 text-white hover:text-white/90 transition-colors font-bold tracking-wide text-lg z-50 focus:outline-none"
            aria-label={`Next: ${next.name}`} data-ps={`src/components/about/Leadership.astro:13zpv0-${__psIdx}`}>
            <span class="hidden md:inline" data-ps={`src/components/about/Leadership.astro:56do2e-${__psIdx}`}>{next.name}</span>
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </button>
        )}

        <div class="relative w-[95%] sm:w-[90%] max-w-2xl flex flex-col max-h-[90vh]" data-ps="src/components/about/Leadership.astro:t3b29">
        
        <div id={`top-bio-${member.id}`} class="bg-white backdrop-blur-xl border border-white/70 shadow-2xl rounded-3xl overflow-hidden shrink-0 relative transition-all duration-500" data-ps="src/components/about/Leadership.astro:t3b30">
        <!-- Close Button -->
        <button
        onclick={`document.getElementById('modal-${member.id}').close()`}
        class="absolute top-4 right-4 sm:top-6 sm:right-6 z-20 w-10 h-10 rounded-full bg-dark/10 hover:bg-dark/20 flex items-center justify-center text-dark transition-colors focus:outline-none focus:ring-2 focus:ring-dark"
        aria-label="Close profile"
        data-ps="src/components/about/Leadership.astro:8d142p">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
        </button>

        <div class="flex flex-col md:flex-row w-full" data-ps="src/components/about/Leadership.astro:7c332k">
        <!-- Image -->
        <div class="w-full md:w-2/5 aspect-square md:aspect-auto relative" data-ps="src/components/about/Leadership.astro:p8v49">
        {member.image ? (
        <>
        <img 
        src={member.image} 
        alt={member.name}
        class:list={[
        "w-full h-full object-cover",
        { "object-[50%_0%]": member.id === 'karan-nagda' },
        { "object-[50%_20%]": member.id === 'atiq-kapadia' },
        (member.imageComingSoon || member.imageNotAvailable) && "blur-md opacity-50 grayscale-[50%]"
        ]}
        data-ps="src/components/about/Leadership.astro:x9v92"/>
        {(member.imageComingSoon || member.imageNotAvailable) && (
          <div class="absolute inset-0 flex items-center justify-center bg-white/40 backdrop-blur-md" data-ps={`src/components/about/Leadership.astro:kcs773-${__psIdx}`}>
            <span class="text-white font-bold tracking-widest text-sm uppercase px-5 py-2 bg-dark/70 rounded-full text-center shadow-lg" data-ps={`src/components/about/Leadership.astro:56do2c-${__psIdx}`}>Image not available</span>
          </div>
        )}
        </>
        ) : (
        <div class="w-full h-full flex items-center justify-center bg-gray-100 text-muted-foreground font-medium" data-ps={`src/components/about/Leadership.astro:kcs773-${__psIdx}`}>
          {member.imageNotAvailable ? "Image not available" : "Image coming soon"}
        </div>
        )}
        </div>
          
        <!-- Content -->
        <div class="w-full md:w-3/5 p-8 md:p-10 flex flex-col justify-center" data-ps="src/components/about/Leadership.astro:k4m38">
        <h3 class="text-3xl font-bold text-dark mb-2" data-ps={`src/components/about/Leadership.astro:p0xn5i-${__psIdx}`}>{member.name}</h3>
        <p class="text-sm font-bold uppercase tracking-widest text-muted-foreground mb-6 whitespace-pre-line" data-ps={`src/components/about/Leadership.astro:2cf0q5-${__psIdx}`}>{member.role}</p>
            
        <div class="w-12 h-1 bg-border rounded-full mb-6" data-ps="src/components/about/Leadership.astro:m9k12"></div>
            
        <p class="text-dark/80 leading-relaxed mb-6" data-ps={`src/components/about/Leadership.astro:2cf0q6-${__psIdx}`}>
        {member.bio}
        </p>

        {member.quote && (
        <div class="mb-8 min-h-[4rem] flex flex-col justify-center" data-ps={`src/components/about/Leadership.astro:quote-container-${__psIdx}`}>
        <p class="text-[#00A896] font-medium italic relative pl-6 border-l-2 border-[#00A896]/30" data-ps={`src/components/about/Leadership.astro:quote-text-${__psIdx}`}>
        "{member.quote}"
        </p>
        </div>
        )}

        <!-- Social Icons -->
        <div class="flex items-center gap-4 mt-8 flex-wrap" data-ps="src/components/about/Leadership.astro:n2b38">
        <a 
        href={member.linkedin || "#"} 
        target={member.linkedin ? "_blank" : undefined}
        rel={member.linkedin ? "noopener noreferrer" : undefined}
        class="w-10 h-10 rounded-full bg-white/50 border border-white/60 flex items-center justify-center text-dark/70 hover:text-primary hover:border-primary transition-colors" 
        title="LinkedIn" 
        data-ps="src/components/about/Leadership.astro:c9v27">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
        </a>

        <a 
        href={member.email ? `mailto:${member.email}` : "#"} 
        target={member.email ? "_blank" : undefined}
        class="group/email relative w-10 h-10 rounded-full bg-white/50 border border-white/60 flex items-center justify-center text-dark/70 hover:text-primary hover:border-primary transition-colors" 
        title={!member.email ? "Email" : ""}
        data-ps="src/components/about/Leadership.astro:w3m92">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
        {member.email && (
        <span class="absolute bottom-full left-1/2 -translate-x-1/2 mb-3 px-3 py-1.5 bg-dark text-white text-[10px] md:text-xs font-medium rounded-lg opacity-0 group-hover/email:opacity-100 transition-all duration-300 whitespace-nowrap pointer-events-none shadow-xl border border-white/10 flex flex-col items-center z-30" data-ps={`src/components/about/Leadership.astro:56do2e-${__psIdx}`}>
        {member.email}
        <span class="absolute top-full left-1/2 -translate-x-1/2 w-2 h-2 bg-dark rotate-45 border-r border-b border-white/10 -mt-1" data-ps={`src/components/about/Leadership.astro:56do2f-${__psIdx}`}></span>
        </span>
        )}
        </a>
              
        {member.extendedBio && (
        <button 
        onclick={`
        const content = document.getElementById('expanded-bio-${member.id}');
        const topBio = document.getElementById('top-bio-${member.id}');
        const isExpanded = content.classList.contains('grid-rows-[0fr]');
        if(isExpanded) {
        content.classList.remove('grid-rows-[0fr]', 'opacity-0');
        content.classList.add('grid-rows-[1fr]', 'opacity-100');
        topBio.classList.remove('rounded-3xl');
        topBio.classList.add('rounded-t-3xl', 'rounded-b-none');
        this.innerText = 'HIDE BIO';
        } else {
        content.classList.add('grid-rows-[0fr]', 'opacity-0');
        content.classList.remove('grid-rows-[1fr]', 'opacity-100');
        topBio.classList.remove('rounded-t-3xl', 'rounded-b-none');
        topBio.classList.add('rounded-3xl');
        this.innerText = 'PROFILE BIO';
        }
        `}
        class="ml-auto px-5 py-2 rounded-2xl bg-white border border-[#0A1931] text-[#0A1931] text-xs font-bold tracking-widest uppercase hover:bg-[#0A1931] hover:text-white transition-all duration-300"
        data-ps={`src/components/about/Leadership.astro:13zpv2-${__psIdx}`}>
        PROFILE BIO
        </button>
        )}
        </div>

        </div>
        </div>
        </div>
        
        {member.extendedBio && (
