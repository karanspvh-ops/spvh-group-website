        <h3 class="text-2xl font-bold text-white mb-4 group-hover:text-secondary transition-all duration-300" data-ps="src/components/about/Beliefs.astro:4vahwm">Trust & Integrity</h3>
        <p class="text-dark-muted leading-relaxed group-hover:text-secondary/90 transition-all duration-300" data-ps="src/components/about/Beliefs.astro:clu4v8">
