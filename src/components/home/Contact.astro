---
---

<section id="contact" class="py-[96px] bg-dark" data-ps="src/components/home/Contact.astro:hfh232">
  <div class="max-w-[1280px] mx-auto px-6 lg:px-12" data-ps="src/components/home/Contact.astro:o1wuzd">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-20 items-center" data-ps="src/components/home/Contact.astro:o1wuzc">
      <!-- Left Content -->
      <div class="reveal" data-ps="src/components/home/Contact.astro:o1wuzb">
        <span class="text-[12px] font-bold uppercase tracking-[2px] text-secondary mb-4 block" data-ps="src/components/home/Contact.astro:jamzt2">INQUIRIES</span>
        <h2 class="text-[48px] font-bold text-white mb-8" data-ps="src/components/home/Contact.astro:hp7u2l">Get in Touch.</h2>
        <p class="text-[18px] text-dark-muted mb-12 leading-relaxed max-w-md" data-ps="src/components/home/Contact.astro:u4l0bm">Reach out to our team to Explore more about our Group Investments, Business Verticals and JV Opportunities to explore your next leap of expansion.</p>

        <div class="space-y-6" data-ps="src/components/home/Contact.astro:o1wuza">
          <div class="flex items-center gap-4 text-dark-muted" data-ps="src/components/home/Contact.astro:1ijz29:left">
            <div class="w-10 h-10 rounded-full border border-white/10 flex items-center justify-center text-secondary" data-ps="src/components/home/Contact.astro:1ijz25">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            </div>
            <a href="mailto:info@spvhgroup.com" class="text-dark-muted no-underline hover:text-white transition-colors" data-ps="src/components/home/Contact.astro:xsl4yc">info@spvhgroup.com</a>
          </div>

          <div class="flex items-center gap-4 text-dark-muted" data-ps="src/components/home/Contact.astro:1ijz26">
            <div class="w-10 h-10 rounded-full border border-white/10 flex items-center justify-center text-secondary" data-ps="src/components/home/Contact.astro:1ijz27">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <span data-ps="src/components/home/Contact.astro:jamzt1">India | UAE | Singapore</span>
          </div>
        </div>
      </div>

      <!-- Right Form -->
      <div class="reveal reveal-right" data-ps="src/components/home/Contact.astro:1ijz28">
        <div class="bg-[#222836] rounded-2xl p-8 lg:p-12 shadow-2xl border border-white/5" data-ps="src/components/home/Contact.astro:1ijz29">
          <div id="contact-status" class="hidden mb-6 px-4 py-3 rounded-lg text-sm" data-ps="src/components/home/Contact.astro:1ijz2e"></div>
          <form id="contact-form" class="space-y-6">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6" data-ps="src/components/home/Contact.astro:1ijz2a">
              <div class="space-y-2" data-ps="src/components/home/Contact.astro:1ijz2b">
                <label class="text-[12px] font-bold text-dark-muted uppercase" data-ps="src/components/home/Contact.astro:tikbbh">Name</label>
                <input 
                  type="text" 
                  name="name"
                  required
                  placeholder="John Doe"
                  class="w-full bg-transparent border border-white/10 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-primary transition-colors"
                />
              </div>
              <div class="space-y-2" data-ps="src/components/home/Contact.astro:1ijz2c">
                <label class="text-[12px] font-bold text-dark-muted uppercase" data-ps="src/components/home/Contact.astro:tikbbi">Email</label>
                <input 
                  type="email" 
                  name="email"
                  required
                  placeholder="john@example.com"
                  class="w-full bg-transparent border border-white/10 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-primary transition-colors"
                />
              </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6" data-ps="src/components/home/Contact.astro:1ijz2a:extended">
              <div class="space-y-2" data-ps="src/components/home/Contact.astro:1ijz2b:company">
                <label class="text-[12px] font-bold text-dark-muted uppercase" data-ps="src/components/home/Contact.astro:tikbbh:company">Company Name</label>
                <input 
                  type="text" 
                  name="company"
                  placeholder="Company Ltd."
                  class="w-full bg-transparent border border-white/10 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-primary transition-colors"
                />
              </div>
              <div class="space-y-2" data-ps="src/components/home/Contact.astro:1ijz2c:website">
                <label class="text-[12px] font-bold text-dark-muted uppercase" data-ps="src/components/home/Contact.astro:tikbbi:website">Website (Optional)</label>
                <input 
                  type="text" 
                  name="website"
                  placeholder="www.xyz.com"
                  class="w-full bg-transparent border border-white/10 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-primary transition-colors"
                />
              </div>
            </div>

            <div class="space-y-2" data-ps="src/components/home/Contact.astro:1ijz2d:vertical">
              <label class="text-[12px] font-bold text-dark-muted uppercase" data-ps="src/components/home/Contact.astro:tikbbj:vertical">Select Vertical</label>
              <select 
                name="vertical"
                required
                class="w-full bg-[#222836] border border-white/10 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-primary transition-colors appearance-none"
              >
                <option value="" disabled selected>Select a business vertical</option>
                <option value="Financial Services">Financial Services</option>
                <option value="Automotive">Automotive</option>
                <option value="Hospitality">Hospitality</option>
                <option value="Real Estate & Interior Design">Real Estate & Interior Design</option>
                <option value="Technology & Research">Technology & Research</option>
                <option value="Media & Entertainment">Media & Entertainment</option>
              </select>
            </div>

            <div class="space-y-2" data-ps="src/components/home/Contact.astro:1ijz2d">
              <label class="text-[12px] font-bold text-dark-muted uppercase" data-ps="src/components/home/Contact.astro:tikbbj">Subject</label>
              <input 
                type="text" 
                name="subject"
                required
                placeholder="Inquiry about..."
                class="w-full bg-transparent border border-white/10 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-primary transition-colors"
              />
            </div>

            <div class="space-y-2" data-ps="src/components/home/Contact.astro:1ijz2e">
              <label class="text-[12px] font-bold text-dark-muted uppercase" data-ps="src/components/home/Contact.astro:tikbbk">Message</label>
              <textarea 
                name="message"
                required
                rows="4" 
                placeholder="Your message here..."
                class="w-full bg-transparent border border-white/10 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-primary transition-colors resize-none"
              ></textarea>
            </div>

            <div class="flex justify-center" data-ps="src/components/home/Contact.astro:altcha-container">
              <altcha-widget challenge="/psapi-internal-v1/altcha/challenge" display="invisible" auto="onfocus"></altcha-widget>
            </div>

            <button 
              type="submit"
              id="contact-submit"
              class="w-full bg-secondary text-white font-bold uppercase tracking-wider py-4 rounded-xl hover:bg-secondary-hover transition-colors shadow-lg"
             data-ps="src/components/home/Contact.astro:1yomzn">
              SEND MESSAGE
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const status = document.getElementById('contact-status') as HTMLDivElement;
  const submitBtn = document.getElementById('contact-submit') as HTMLButtonElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    submitBtn.disabled = true;
    submitBtn.textContent = 'SENDING...';

    const formData = new FormData(form);
    const data = Object.fromEntries(formData);
    
    // Add auto-acknowledgment fields
    data._confirmationSubject = "We received your inquiry - SPVH Group";
    data._confirmationBody = "Thank you for reaching out to SPVH Group. We have received your message and our team will get back to you shortly.\n\nBest regards,\nSPVH Group Team";

    try {
      const response = await fetch('/psapi-internal-v1/forms/submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      const result = await response.json();

      if (result.success) {
        status.className = 'mb-6 px-4 py-3 rounded-lg bg-secondary/20 border border-secondary text-secondary text-sm';
        status.textContent = 'Thank you! Your message has been sent.';
        form.reset();
      } else {
        throw new Error(result.error || 'Failed to send');
      }
    } catch (err) {
      status.className = 'mb-6 px-4 py-3 rounded-lg bg-red-500/20 border border-red-500 text-red-500 text-sm';
      status.textContent = err instanceof Error ? err.message : 'Failed to send. Please try again.';
    } finally {
      status.classList.remove('hidden');
      submitBtn.disabled = false;
      submitBtn.textContent = 'SEND MESSAGE';
    }
  });
</script>
